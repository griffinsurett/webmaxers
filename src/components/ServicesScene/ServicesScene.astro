---
// src/components/ServicesScene/ServicesScene.astro
/**
 * ServicesScene — a pinned, scroll-scrubbed services reveal over a fixed fire
 * background.
 *
 * Phases (a single GSAP-scrubbed timeline while the section is pinned):
 *   Phase 1  the fire background un-dims (barely visible → fully visible) via a
 *            dim overlay whose opacity is scrubbed from 1 → 0 while the intro
 *            label stack reads "Websites / Branding / Ai Agents".
 *   Phase 2  the intro scrolls out of frame and then the service cards slide IN
 *            from alternating sides.
 *   Phase 3  the card list scrolls vertically through the pin so all cards are
 *            reachable while the section + background stay fixed.
 *
 * The section owns its own pin (GSAP ScrollTrigger). On the homepage it's
 * stacked directly behind the filmstrip (see index.astro) so the filmstrip
 * peels off-left to reveal it already in place. Below 768px / reduced-motion
 * GSAP registers nothing and the CSS flattens to a static vertical layout.
 */

import Icon from "@/components/Icon";
import { query, sortByOrder } from "@/utils/query";
import { prepareCollectionEntries, getCollectionMeta } from "@/utils/collections";
import { getImage } from "astro:assets";
import servicesBg from "@/assets/fire-pic.jpg";

// Optimized responsive sources for the fixed fire background. Rendered as a real
// <img> (i75 FixedViewportBackground pattern) — NOT background-attachment:fixed,
// which iOS ignores. The layer is pinned to the viewport via the scroll system
// on desktop and position:sticky on mobile, so it stays put on touch too.
const [bgMobile, bgTablet, bgDesktop] = await Promise.all([
  getImage({ src: servicesBg, format: "webp", quality: 68, width: 768 }),
  getImage({ src: servicesBg, format: "webp", quality: 72, width: 1280 }),
  getImage({ src: servicesBg, format: "webp", quality: 74, width: 1920 }),
]);

interface Props {
  /** Outer box height. GSAP's pin-spacer provides the scroll budget, so this
   *  is just the in-flow footprint — one viewport. */
  sceneHeight?: string;
}

const { sceneHeight = "100vh" } = Astro.props;

// Load the 6 services.
const meta = getCollectionMeta("services");
const result = await query("services").orderBy(sortByOrder()).get();
const services = await prepareCollectionEntries(result.entries, "services", meta);

const introLines = ["Websites", "Branding", "Ai Agents"];
---

<section
  class="services-scene"
  data-services-scene
  style={`--scene-height:${sceneHeight};`}
  aria-label="Our services"
>
  <div class="services-pin">
    {/* Fire background behind every phase. A real <img> layer (i75
        FixedViewportBackground pattern) — locked to the viewport by GSAP's pin
        on desktop and by position:sticky on mobile, so it stays fixed while the
        content scrolls over it on touch devices too (background-attachment:fixed
        is ignored on iOS, so we don't use it). */}
    <div class="services-bg" aria-hidden="true">
      <picture>
        <source media="(max-width: 640px)" srcset={bgMobile.src} type="image/webp" />
        <source media="(min-width: 641px) and (max-width: 1024px)" srcset={bgTablet.src} type="image/webp" />
        <source media="(min-width: 1025px)" srcset={bgDesktop.src} type="image/webp" />
        <img src={bgDesktop.src} alt="" class="h-full w-full object-cover object-center" loading="lazy" decoding="async" fetchpriority="low" />
      </picture>
      {/* Light residual overlay — the scroll-driven .services-dim does the rest. */}
      <div class="absolute inset-0 bg-black/30"></div>
    </div>

    {/* Phase 1 — dim layer over the fire. Starts opaque (image barely visible)
        and fades to transparent on scroll (image fully visible). */}
    <div class="services-dim" data-services-dim aria-hidden="true"></div>

    {/* Intro stack — shown before the cards arrive, then fades out as the
        cards begin to enter. */}
    <div class="services-intro" data-services-intro aria-hidden="true">
      <div class="services-intro-inner">
        <div class="services-intro-copy" data-services-intro-copy>
          <p class="services-intro-eyebrow">OUR SERVICES</p>
          <div class="services-intro-stack">
            {introLines.map((line) => (
              <span class="services-intro-line">{line}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    {/* Phase 2 — service cards slide in from alternating sides */}
    <div class="services-cards-wrap" data-services-cards>
      {/* Inner scroller — scrubbed vertically by the tail of the scroll so all
          cards are reachable while the section + bg stay pinned. */}
      <div class="services-cards-scroll" data-services-cards-scroll>
        <ul class="services-cards-grid list-none">
          {services.map((item, i) => (
            <li
              class="svc-card"
              data-svc-card
              style={`--card-from:${i % 2 === 0 ? "-1" : "1"};`}
            >
              {item.icon && (
                <Icon icon={item.icon} size="lg" className="text-primary-light/80" />
              )}
              <h3 class="svc-card-title">{item.title}</h3>
              {item.description && <p class="svc-card-desc">{item.description}</p>}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .services-scene {
    position: relative;
    height: var(--scene-height);
  }

  .services-pin {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Fire background layer. Desktop: fills the GSAP-pinned .services-pin (the pin
     keeps it fixed to the viewport during the scrubbed sequence). The inner
     <picture>/<img> covers the box. */
  .services-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .services-bg picture,
  .services-bg img {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── Dim layer (phase 1) ─────────────────────────────────────────
     Over the fire image, under the cards. Opacity driven by JS: starts
     near-opaque (image barely visible) → fades to 0 (fully visible). */
  .services-dim {
    --dim: 1; /* 1 = fully dimmed, 0 = fully visible; set by JS */
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #000;
    /* Start partially dimmed (not near-black) so the fire is visible coming out
       of the container above, then fully clears as you scroll. */
    opacity: calc(var(--dim) * 0.5);
    will-change: opacity;
    pointer-events: none;
  }

  /* ── Intro stack (pre-card state) ─────────────────────────────── */
  .services-intro {
    --intro-shift: 0vh;
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 1;
  }

  .services-intro-inner {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1.5rem, 6vw, 6rem);
  }

  .services-intro-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.5rem, 1.2vw, 0.85rem);
    text-align: center;
    opacity: var(--intro-opacity, 1);
    transform: translateY(calc(-2.5vh - var(--intro-shift, 0vh)));
    will-change: transform, opacity;
  }

  .services-intro-eyebrow {
    font-size: 0.9rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-primary-light) 72%, transparent);
  }

  .services-intro-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(0.35rem, 0.8vw, 0.65rem);
    align-self: center;
    justify-self: center;
    text-align: center;
    color: var(--color-primary-light);
    text-transform: uppercase;
    letter-spacing: -0.09em;
    font-weight: 300;
    line-height: 0.8;
  }

  .services-intro-line {
    font-size: clamp(3.5rem, 8.6vw, 9.2rem);
    text-wrap: balance;
  }

  /* ── Cards (phase 2 + 3) ─────────────────────────────────────────
     The wrap is a fixed-height clipping viewport; the inner scroller is
     translated vertically by the tail of the scroll so every card is reachable
     while the section + background stay pinned. */
  .services-cards-wrap {
    position: absolute;
    inset: 0;
    z-index: 3;
    overflow: hidden;
    pointer-events: none; /* enabled by JS once cards are in */
  }

  .services-cards-scroll {
    --cards-scroll: 0px; /* set by JS in the scroll sub-phase */
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.5rem;
    padding: clamp(3rem, 8vh, 6rem) clamp(1.5rem, 6vw, 6rem);
    transform: translateY(var(--cards-scroll));
    will-change: transform;
  }

  .services-cards-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.5rem 4rem;
  }

  .svc-card {
    --card-progress: 0; /* 0 → 1 set by JS in phase 2 */
    --card-from: -1;    /* -1 = enters from left, 1 = from right */
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    /* Faded glass panel behind each card */
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--color-primary-light) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary-light) 12%, transparent);
    backdrop-filter: blur(6px);
    transform: translateX(calc(var(--card-from) * (1 - var(--card-progress)) * 60vw));
    opacity: var(--card-progress);
    will-change: transform, opacity;
  }

  .svc-card-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--color-primary-light);
  }
  .svc-card-desc {
    color: color-mix(in srgb, var(--color-primary-light) 75%, transparent);
    line-height: 1.6;
    max-width: 42ch;
  }

  /* ── Flatten: mobile + reduced motion ────────────────────────── */
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    .services-scene { height: auto; }
    .services-pin { position: static; height: auto; overflow: visible; display: block; padding: 5rem 0; }
    .services-dim { display: none; }
    /* Fixed-to-viewport fire background on touch (i75 pattern, sticky variant):
       the layer sticks to the viewport top through the whole section while the
       content scrolls over it. The negative margin removes it from flow so it
       doesn't push the content down. Content sits above via z-index. */
    .services-bg {
      position: sticky;
      top: 0;
      height: 100vh;
      margin-bottom: -100vh;
      z-index: 0;
    }
    .services-intro,
    .services-cards-wrap { position: relative; z-index: 1; }
    .services-intro { inset: auto; opacity: 1; transform: none; padding: 0 1.5rem 2rem; }
    .services-intro-inner {
      padding: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
    }
    .services-intro-copy {
      transform: none !important;
      opacity: 1 !important;
      gap: 0.35rem;
    }
    .services-intro-stack {
      gap: 0.25rem;
    }
    .services-intro-line {
      font-size: clamp(2.8rem, 10vw, 4.8rem);
    }
    .services-cards-wrap {
      position: relative;
      inset: auto;
      overflow: visible;
      pointer-events: auto;
      opacity: 1;
    }
    .services-cards-scroll {
      transform: none !important;
      padding: 0 1.5rem;
      will-change: auto;
    }
    .services-cards-grid {
      grid-template-columns: 1fr;
    }
    .svc-card {
      transform: none !important;
      opacity: 1 !important;
      transition: none !important;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function clamp(v: number, lo: number, hi: number) {
    return v < lo ? lo : v > hi ? hi : v;
  }

  // Apply all three phases for a given normalized progress p (0→1). Same phase
  // boundaries and math as the original — only the driver changed (GSAP instead
  // of a hand-rolled rAF loop).
  function applyPhases(scene: HTMLElement, p: number) {
    const dim = scene.querySelector<HTMLElement>("[data-services-dim]");
    const introCopy = scene.querySelector<HTMLElement>("[data-services-intro-copy]");
    const cardsWrap = scene.querySelector<HTMLElement>("[data-services-cards]");
    const cardsScroll = scene.querySelector<HTMLElement>("[data-services-cards-scroll]");
    const cards = scene.querySelectorAll<HTMLElement>("[data-svc-card]");

    // Phase boundaries (fractions of the pinned scroll budget).
    const REVEAL_END = 0.3;    // background fully un-dimmed
    const INTRO_END = 0.22;    // intro stack exits first
    const CARDS_START = 0.30;  // cards begin after the intro has cleared
    const CARDS_IN_END = 0.55; // cards finished sliding in
    // CARDS_IN_END → 1.0 = vertical scroll through the cards.

    // Phase 1 — fire background un-dims (1 → 0).
    const revealP = clamp(p / REVEAL_END, 0, 1);
    if (dim) dim.style.setProperty("--dim", (1 - revealP).toFixed(4));

    if (introCopy) {
      const introP = clamp(p / INTRO_END, 0, 1);
      introCopy.style.setProperty("--intro-shift", (introP * 44).toFixed(4) + "vh");
      introCopy.style.setProperty("--intro-opacity", (1 - introP).toFixed(4));
    }

    // Phase 2 — cards slide in from alternating sides with a stagger.
    const cardsP = clamp((p - CARDS_START) / (CARDS_IN_END - CARDS_START), 0, 1);
    cards.forEach((c, i) => {
      const stagger = i * 0.08;
      let cp = clamp((cardsP - stagger) / (1 - stagger || 1), 0, 1);
      cp = 1 - Math.pow(1 - cp, 3); // ease out for a soft landing
      c.style.setProperty("--card-progress", cp.toFixed(4));
    });

    // Phase 3 — scroll the card list vertically until every card has cleared
    // the top of the frame, so the section only releases once they've exited.
    if (cardsScroll && cardsWrap) {
      const travel = cardsScroll.scrollHeight;
      const scrollP = clamp((p - CARDS_IN_END) / (1 - CARDS_IN_END), 0, 1);
      cardsScroll.style.setProperty("--cards-scroll", (-scrollP * travel).toFixed(1) + "px");
      cardsWrap.style.pointerEvents = cardsP > 0.9 ? "auto" : "none";
    }
  }

  // Extra scroll the phases need, in viewport multiples. Phase 3 scrolls every
  // card fully out of frame before releasing, so the budget is generous.
  const PHASE_VH = 4.5;

  // Standalone (not inside a CurtainStack): self-pin and run the phases.
  function buildStandalone(scene: HTMLElement) {
    const pin = scene.querySelector<HTMLElement>(".services-pin") ?? scene;

    ScrollTrigger.create({
      trigger: scene,
      start: "top top",
      end: () => "+=" + PHASE_VH * window.innerHeight,
      pin,
      scrub: true,
      anticipatePin: 1,
      invalidateOnRefresh: true,
      onUpdate: (self) => applyPhases(scene, self.progress),
    });
  }

  function init() {
    const scenes = document.querySelectorAll<HTMLElement>("[data-services-scene]");
    if (!scenes.length) return;

    scenes.forEach((scene) => {
      // Inside a CurtainStack: the scene is already pinned full-screen by that
      // orchestrator (it stays put while the layer above peels off to expose
      // it). We expose the uniform layer contract — its internal scrub is the
      // phase budget; the stack adds the move-off (slide-up) budget on top.
      const stack = scene.closest("[data-curtain-stack]");
      if (stack) {
        (scene as any).__curtainLayer = {
          getScrubPx: () => PHASE_VH * window.innerHeight,
          setProgress: (p: number) => applyPhases(scene, p),
        };
        return;
      }

      // Standalone — desktop only; CSS flattens below 768px / reduced-motion.
      ScrollTrigger.matchMedia({
        "(min-width: 768px) and (prefers-reduced-motion: no-preference)": () => {
          buildStandalone(scene);
        },
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
