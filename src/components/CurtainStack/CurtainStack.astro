---
// src/components/CurtainStack/CurtainStack.astro
/**
 * CurtainStack — orchestrates a "curtain reveal" chain of stacked full-bleed
 * layers on a single shared pin.
 *
 * Layout (desktop): one pinned full-viewport container. Every child marked
 * `data-curtain-layer` is stacked absolutely inside it. The FIRST layer sits on
 * top (covers everything); the LAST sits at the bottom (revealed last and left
 * in place as the final state). One GSAP timeline runs each layer in turn:
 *
 *   for each layer (top → bottom):
 *     1. internal scrub  — if the layer exposes a __curtainLayer contract, the
 *                          stack drives its own animation (filmstrip track
 *                          slides; services runs its dim/intro/cards phases).
 *     2. move off         — the whole layer slides out of frame in its declared
 *                          `data-move` direction, uncovering the layer beneath:
 *                            "left" → xPercent: -100 (filmstrip peel)
 *                            "up"   → yPercent: -100 (services lifts away)
 *                            "none" → never moves (the bottom layer; final state)
 *
 * Because layers are stacked and revealed by the one above moving off, every
 * reveal is "in place": the layer beneath was already pinned full-screen and
 * stationary — it does not scroll up into view.
 *
 * Each layer's animation logic lives in its own component (which also runs
 * standalone, self-pinning, outside a stack). The stack only sequences them.
 * Add or reorder layers by editing the markup — no code change here.
 *
 * Below 768px / reduced-motion: no pin, no overlay. Layers render in normal
 * flow and each flattens itself (their own CSS fallbacks handle it).
 */

interface Props {
  class?: string;
  /**
   * Also flatten the stack below 768px (in addition to reduced-motion). Use when
   * the layers have their own mobile-static fallbacks that expect NORMAL flow on
   * phones (e.g. the capability card-stack), so the 100vh-clipped curtain frame
   * doesn't cut them off. Leave false for curtains whose layers run their own
   * pin/scrub at every width (e.g. the homepage filmstrip).
   */
  flattenMobile?: boolean;
}

const { class: className = "", flattenMobile = false } = Astro.props;
---

<div
  class:list={["curtain-stack", flattenMobile && "curtain-stack--flatten-mobile", className]}
  data-curtain-stack
  data-flatten-mobile={flattenMobile ? "" : undefined}
>
  <slot />
</div>

<style>
  /* Desktop: a single pinned viewport. GSAP pins .curtain-stack and provides
     the scroll budget via its pin-spacer; layers are absolutely stacked
     inside it (z-index assigned by JS in DOM order: first = top). */
  .curtain-stack {
    position: relative;
    height: 100vh;
    width: 100%;
    overflow: hidden;
  }

  .curtain-stack :global([data-curtain-layer]) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    will-change: transform;
  }

  /* Reduced motion: drop the stack — normal vertical flow, each layer flattens
     itself. By default the curtain runs on every screen size otherwise. */
  @media (prefers-reduced-motion: reduce) {
    .curtain-stack {
      height: auto;
      overflow: visible;
    }
    .curtain-stack :global([data-curtain-layer]) {
      position: static;
      inset: auto;
      height: auto;
      will-change: auto;
    }
  }

  /* Opt-in (flattenMobile): also flatten below 768px so layers with their own
     mobile-static fallbacks sit in normal flow instead of being clipped by the
     100vh curtain frame. */
  @media (max-width: 767px) {
    .curtain-stack--flatten-mobile {
      height: auto;
      overflow: visible;
    }
    .curtain-stack--flatten-mobile :global([data-curtain-layer]) {
      position: static;
      inset: auto;
      height: auto;
      will-change: auto;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollToPlugin } from "gsap/ScrollToPlugin";
  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  function clamp(v: number, lo: number, hi: number) {
    return v < lo ? lo : v > hi ? hi : v;
  }

  interface LayerContract {
    getScrubPx: () => number;
    setProgress: (p: number) => void;
  }

  // Find a layer's animation contract — set on the layer wrapper or any of its
  // animated descendants (filmstrip / services attach it to their own root).
  function contractOf(layer: HTMLElement): LayerContract | null {
    if ((layer as any).__curtainLayer) return (layer as any).__curtainLayer;
    const inner = layer.querySelector<HTMLElement>("[data-filmstrip], [data-cardstack-v], [data-services-scene], [data-logo-scene]");
    return inner ? ((inner as any).__curtainLayer ?? null) : null;
  }

  function buildStack(stack: HTMLElement) {
    const layers = Array.from(
      stack.querySelectorAll<HTMLElement>(":scope > [data-curtain-layer]"),
    );
    if (!layers.length) return;

    const vh = window.innerHeight;

    // Per-layer plan: contract (optional), move-off direction + distance, and
    // the scroll budget each leg consumes. The last layer never moves off.
    const plan = layers.map((layer, i) => {
      const isLast = i === layers.length - 1;
      const move = isLast ? "none" : layer.getAttribute("data-move") ?? "up";
      const contract = contractOf(layer);
      const scrubPx = contract ? Math.max(0, contract.getScrubPx()) : 0;
      const movePx = move === "none" ? 0 : vh; // one viewport to clear the frame
      return { layer, contract, move, scrubPx, movePx };
    });

    // Stack order: first layer on top. Higher z-index = earlier in DOM.
    layers.forEach((layer, i) => {
      layer.style.zIndex = String(layers.length - i);
    });

    const total = plan.reduce((sum, p) => sum + p.scrubPx + p.movePx, 0);
    if (total <= 0) return;

    // Reset every layer to its initial state (progress 0).
    plan.forEach((p) => p.contract?.setProgress(0));

    // Precompute each leg's start/end as fractions of total progress so the
    // single onUpdate can drive the right layer's contract at any scroll point.
    let acc = 0;
    const legs = plan.map((p) => {
      const scrubStart = acc / total;
      acc += p.scrubPx;
      const scrubEnd = acc / total;
      acc += p.movePx;
      const moveEnd = acc / total;
      return { ...p, scrubStart, scrubEnd, moveEnd };
    });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: stack,
        start: "top top",
        end: "+=" + total,
        pin: true,
        scrub: 1,
        anticipatePin: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          const p = self.progress;

          // The "active" layer = the LAST layer (top → bottom) that has not yet
          // finished moving off. Every layer ABOVE it has fully peeled away;
          // every layer BELOW it is still covered. Only the active layer should
          // capture pointer/scroll events — covered layers (especially the
          // resting blog layer, which scrolls internally) must let wheel/scroll
          // fall through to the page so it keeps driving the pin. Otherwise the
          // covered layer's own overflow eats the scroll = a scroll trap.
          let activeIdx = legs.length - 1;
          for (let i = 0; i < legs.length; i++) {
            if (p < legs[i].moveEnd) { activeIdx = i; break; }
          }

          legs.forEach((leg, i) => {
            // Drive each layer's internal scrub across its own scrub window.
            if (leg.contract) {
              const span = leg.scrubEnd - leg.scrubStart;
              const lp = span > 0 ? clamp((p - leg.scrubStart) / span, 0, 1) : 1;
              leg.contract.setProgress(lp);
            }
            const isActive = i === activeIdx;
            // Only the active (topmost still-present) layer is interactive; all
            // others — peeled-away above OR still-covered below — are inert so
            // they can't intercept clicks.
            leg.layer.style.pointerEvents = isActive ? "auto" : "none";
          });
        },
      },
    });

    // Initial state: at rest (progress 0) the first layer is active and every
    // layer beneath it is inert, so nothing below can intercept clicks before
    // the first onUpdate fires.
    legs.forEach((leg, i) => {
      leg.layer.style.pointerEvents = i === 0 ? "auto" : "none";
    });

    // Build the move-off tweens in sequence (internal scrub budget is held by a
    // spacer tween since the scrub itself is applied imperatively in onUpdate).
    legs.forEach((leg) => {
      const scrubDur = leg.scrubEnd - leg.scrubStart;
      if (scrubDur > 0) tl.to({}, { duration: scrubDur });

      const moveDur = leg.moveEnd - leg.scrubEnd;
      if (moveDur > 0 && leg.move !== "none") {
        const vars: gsap.TweenVars =
          leg.move === "left" ? { xPercent: -100 } : { yPercent: -100 };
        tl.to(leg.layer, { ...vars, ease: "none", duration: moveDur });
      }
    });

    // In-stack anchor navigation. A link inside the pinned stack pointing at a
    // layer (or any element within one) — e.g. the services ScrollIndicator's
    // href="#logo-scene" — would natively jump to the stack's start (where the
    // whole pin sits in the document), not to where that layer visually reveals.
    // Intercept those clicks and smooth-scroll to the layer's reveal position:
    // the scroll point where the layer ABOVE it has finished moving off, i.e.
    // this layer's scrubStart on the pinned timeline.
    const st = tl.scrollTrigger!;
    stack.addEventListener("click", (e) => {
      const link = (e.target as HTMLElement | null)?.closest<HTMLAnchorElement>(
        'a[href^="#"]',
      );
      if (!link || !stack.contains(link)) return;
      const id = decodeURIComponent(link.getAttribute("href")!.slice(1));
      const targetEl = id ? document.getElementById(id) : null;
      if (!targetEl) return;
      const idx = legs.findIndex((leg) => leg.layer.contains(targetEl));
      if (idx < 0) return; // not a layer in this stack — let the browser handle it
      e.preventDefault();
      const y = st.start + legs[idx].scrubStart * (st.end - st.start);
      gsap.to(window, {
        scrollTo: { y, autoKill: false },
        duration: 0.9,
        ease: "power2.inOut",
      });
    });
  }

  function init() {
    const stacks = document.querySelectorAll<HTMLElement>("[data-curtain-stack]");
    if (!stacks.length) return;

    // Layers attach their __curtainLayer contracts in their own init() — bundled
    // module-script order isn't guaranteed, so defer one frame to be sure they've
    // all run before we read them.
    requestAnimationFrame(() => {
      // Default stacks run at every width (reduced-motion gets the static flatten).
      const normal = Array.from(stacks).filter((s) => !s.hasAttribute("data-flatten-mobile"));
      // Opt-in stacks ALSO flatten below 768px → only build at desktop width.
      const flatten = Array.from(stacks).filter((s) => s.hasAttribute("data-flatten-mobile"));

      ScrollTrigger.matchMedia({
        "(prefers-reduced-motion: no-preference)": () => {
          normal.forEach(buildStack);
        },
        "(min-width: 768px) and (prefers-reduced-motion: no-preference)": () => {
          flatten.forEach(buildStack);
        },
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
