---
// src/components/ContentRenderer/variants/CardStackVerticalVariant.astro
/**
 * Card Stack Vertical Variant — pinned "cover stack" card section.
 *
 * Card slides only (no intro / outro). Each slide is a real flex container with
 * two halves — media (left) and text (right) — divided by a real border. Slides
 * are absolutely stacked full-screen on one pin; each later slide sits at a
 * higher z-index. On scroll each slide slides UP from below (yPercent 100 → 0)
 * and COVERS the one before it (the homepage CurtainStack feel). No fade.
 *
 * Sequence (GSAP ScrollTrigger, self-pinned):
 *   - slide 0 rests full-screen.
 *   - each slide i ≥ 1 slides up to cover slide i-1 over ~1vh of scroll.
 *   - finally the whole section peels off the top (~1vh) to reveal what follows.
 *
 * Fallback: <768px / reduced-motion → static vertical stack, normal scroll.
 *
 * Layout is plain Tailwind on real containers — no absolute-overlay rules, no
 * :global hacks on the shared card — so it centres and restyles cleanly.
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import FilmstripCardMedia from "@/components/LoopComponents/FilmstripCardMedia.astro";
import CapabilityChildrenVariant from "./CapabilityChildrenVariant.astro";

type Props = BaseVariantProps;

const { items = [], title = "", id, placeholderMedia = false } = Astro.props as Props & {
  placeholderMedia?: boolean;
};
---

<section
  id={id}
  class="csv-section relative h-screen w-full overflow-hidden border-y border-text/12"
  data-cardstack-v
  aria-label={title?.replace?.("\n", " ") ?? "Cards"}
>
  {items.map((item, i) => {
    // This capability's child sub-capabilities — at most 6 lines.
    const childItems = (item.includes ?? []).slice(0, 6);

    return (
      <article
        class="csv-slide absolute inset-0 flex h-full w-full items-stretch border border-text/12 bg-linear-to-r from-bg3 to-bg"
        data-cardstack-v-card
        data-slide-index={i + 1}
      >
        {/* The actual card: one full-width row, two equal halves, a real divider. */}
        <div class="grid h-full w-full grid-cols-1 md:grid-cols-2">
          {/* ── Media half (left) ── */}
          <div class="flex h-full min-h-0 items-center justify-center px-(--csv-half-pad) py-(--csv-half-pad)">
            <div class="aspect-[20/13] w-full max-w-[52rem] overflow-hidden">
              {placeholderMedia ? (
                <div class="h-full w-full bg-bg" aria-hidden="true"></div>
              ) : (
                <FilmstripCardMedia
                  title={item.title}
                  featuredVideo={item.featuredVideo}
                  fullSiteImage={item.fullSiteImage}
                  bannerImage={item.bannerImage}
                  featuredImage={item.featuredImage}
                />
              )}
            </div>
          </div>

          {/* ── Text half (right) — divider is a real left border on desktop
              only; on mobile (stacked) there's no divider between the halves. ── */}
          <div class="flex h-full min-h-0 px-(--csv-half-pad) py-(--csv-half-pad) md:border-l md:border-text/12">
            <div class="flex w-full flex-col justify-center gap-4 text-left md:max-w-[34rem]">
              {/* Parent capability: title (large) + description */}
              <h3 class="text-2xl font-medium leading-tight tracking-tight text-heading md:text-3xl">{item.title}</h3>

              {item.description && (
                <p class="text-sm font-light leading-relaxed text-text/65">{item.description}</p>
              )}

              {/* Child sub-capabilities (max 6) — its own variant of React rows.
                  Each row's text staggers in and its divider line draws in
                  left→right; that animation is driven by this card's GSAP
                  timeline below via the rows' data-csv-child-* markers. */}
              <CapabilityChildrenVariant items={childItems} max={6} />
            </div>
          </div>
        </div>
      </article>
    );
  })}
</section>

<style>
  /* Layout knobs only — everything visual is Tailwind on the markup above. */
  [data-cardstack-v] {
    --csv-half-pad: clamp(1.5rem, 3.5vw, 4rem);
  }

  @media (max-width: 767px) {
    [data-cardstack-v] {
      --csv-half-pad: clamp(1.25rem, 5vw, 2rem);
    }
  }

  .csv-slide { will-change: transform; }

  /* Hide the child text + collapse the divider lines up front for motion-OK
     users (BOTH desktop and mobile — the row reveal animation runs on both;
     only the 3D pin is desktop-only) so they don't flash before GSAP sets their
     start state. Reduced-motion users skip this and see everything immediately. */
  @media (prefers-reduced-motion: no-preference) {
    .csv-child-text { opacity: 0; }
    .csv-child-line { transform: scaleX(0); transform-origin: left center; }
  }

  /* ── Static fallback: mobile (<768px) OR reduced-motion ───────────
     The desktop cover-stack (pin + slide-up-to-cover) only runs at ≥768px for
     motion-OK users; everywhere else there is NO 3D effect. The slides drop out
     of the absolute stack into normal document flow — just one card on top of
     the next, scrolling the page normally. Mirrors the JS matchMedia gate so the
     two never disagree. */
  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    .csv-section {
      height: auto;
      overflow: visible;
    }
    .csv-slide {
      position: static;
      inset: auto;
      /* Each flattened card is at least a full viewport tall; if its content is
         taller it just grows and pushes the next card down (no clipping). */
      min-height: 100svh;
      height: auto;
      transform: none !important;
      will-change: auto;
      /* z-index from the desktop JS is irrelevant in flow, but reset it anyway. */
      z-index: auto !important;
    }
    /* Give each stacked card breathing room and its own top divider so the
       boundaries still read in the flat layout (the slide's own border-y does
       most of the work; this just keeps adjacent borders from doubling oddly). */
    .csv-slide + .csv-slide {
      border-top: 0;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // ── Shared row-reveal helpers (used by both the desktop cover-stack and the
  //    flat mobile path — the row animation runs on both; only the 3D pin is
  //    desktop-only). ──────────────────────────────────────────────────────
  const textsOf = (slide: HTMLElement) =>
    Array.from(slide.querySelectorAll<HTMLElement>("[data-csv-child-text]"));
  const linesOf = (slide: HTMLElement) =>
    Array.from(slide.querySelectorAll<HTMLElement>("[data-csv-child-line]"));

  // Reset a card's child rows to their hidden start state.
  const hideChildren = (slide: HTMLElement) => {
    gsap.set(textsOf(slide), { autoAlpha: 0, y: 16 });
    gsap.set(linesOf(slide), { scaleX: 0, transformOrigin: "left center" });
  };

  // Play a card's child rows IN: each line draws left→right, each text fades +
  // rises, staggered row by row (line leads slightly, like the process rail).
  // A fresh tween each time, so it replays whenever the card is (re)entered.
  const playChildren = (slide: HTMLElement) => {
    const texts = textsOf(slide);
    const lines = linesOf(slide);
    gsap.killTweensOf([...texts, ...lines]);
    gsap.set(texts, { autoAlpha: 0, y: 16 });
    gsap.set(lines, { scaleX: 0, transformOrigin: "left center" });
    const t = gsap.timeline();
    t.to(lines, { scaleX: 1, ease: "power2.out", duration: 0.5, stagger: 0.1 }, 0);
    t.to(texts, { autoAlpha: 1, y: 0, ease: "power2.out", duration: 0.55, stagger: 0.1 }, 0.08);
    return t;
  };

  // Flat (mobile) path: NO 3D pin/cover-stack — slides are in normal flow (CSS
  // fallback). Each card just plays its row reveal when it scrolls into view,
  // and replays on re-entry (both scroll directions). Same text/line animation.
  function buildFlat(section: HTMLElement) {
    const slides = Array.from(
      section.querySelectorAll<HTMLElement>("[data-cardstack-v-card]"),
    );
    slides.forEach((slide) => {
      hideChildren(slide);
      ScrollTrigger.create({
        trigger: slide,
        start: "top 80%",
        end: "bottom 20%",
        onEnter: () => playChildren(slide),
        onEnterBack: () => playChildren(slide),
        onLeave: () => hideChildren(slide),
        onLeaveBack: () => hideChildren(slide),
      });
    });
  }

  // Cover-stack driver: slides are absolutely stacked; each later slide rises up
  // (yPercent 100 → 0) to cover the previous one. Driving is by a 0→1 progress,
  // so the SAME logic works whether we self-pin (standalone) or a CurtainStack
  // feeds the progress and adds its own move-off (peel) on top. Returns the
  // uniform { getScrubPx, setProgress } layer contract.
  function makeDriver(section: HTMLElement) {
    const slides = Array.from(
      section.querySelectorAll<HTMLElement>("[data-cardstack-v-card]"),
    );

    slides.forEach((slide, i) => {
      slide.style.zIndex = String(i + 1);
      gsap.set(slide, { yPercent: i === 0 ? 0 : 100 });
      hideChildren(slide); // rows reveal as each card becomes active
    });

    // (slides.length - 1) card-to-card cover transitions, one viewport each.
    const coverCount = Math.max(slides.length - 1, 0);

    // Replay a card's child rows whenever it becomes the active (top) card.
    let lastActive = -1;
    const setActive = (active: number) => {
      if (active === lastActive) return;
      if (lastActive >= 0 && slides[lastActive]) hideChildren(slides[lastActive]);
      if (slides[active]) playChildren(slides[active]);
      lastActive = active;
    };

    return {
      // Scroll budget the covers need (the stack adds its move-off on top).
      getScrubPx: () => window.innerHeight * Math.max(coverCount, 1),
      // Drive the stack to a 0→1 progress: position each card + activate rows.
      setProgress: (p: number) => {
        const total = Math.max(coverCount, 1);
        const t = Math.min(Math.max(p, 0), 1) * total;
        let active = 0;
        for (let i = 1; i < slides.length; i++) {
          // Card i's cover runs t in (i-1)→i; yPercent 100→0 across that unit.
          const local = Math.min(Math.max(t - (i - 1), 0), 1);
          gsap.set(slides[i], { yPercent: (1 - local) * 100 });
          if (t >= i - 0.5) active = i; // activate ~halfway through its cover
        }
        setActive(active);
      },
    };
  }

  // Standalone (not in a CurtainStack): self-pin and scrub the driver. The last
  // card rests in place and the pin releases into normal flow — no trailing peel.
  function buildStandalone(section: HTMLElement) {
    const driver = makeDriver(section);
    const scrubPx = driver.getScrubPx();
    ScrollTrigger.create({
      trigger: section,
      start: "top top",
      end: "+=" + scrubPx,
      pin: true,
      scrub: 1,
      anticipatePin: 1,
      invalidateOnRefresh: true,
      onRefreshInit: () => driver.setProgress(0),
      onUpdate: (self) => driver.setProgress(self.progress),
    });
  }

  function init() {
    const sections = document.querySelectorAll<HTMLElement>("[data-cardstack-v]");
    if (!sections.length) return;
    sections.forEach((section) => {
      // Inside a CurtainStack: don't self-pin. Expose the uniform layer contract
      // so the stack drives the covers as one leg of its shared timeline, then
      // peels this whole layer off to reveal the section beneath (testimonials).
      // (Desktop, motion OK only — mobile/reduced-motion fall through to flat.)
      const stack = section.closest("[data-curtain-stack]");
      if (stack && window.matchMedia("(min-width: 768px) and (prefers-reduced-motion: no-preference)").matches) {
        const driver = makeDriver(section);
        (section as any).__curtainLayer = {
          getScrubPx: () => driver.getScrubPx(),
          setProgress: (p: number) => driver.setProgress(p),
        };
        return;
      }

      // matchMedia auto-reverts/reruns each setup when crossing a breakpoint.
      ScrollTrigger.matchMedia({
        // Desktop, motion OK → the full 3D pinned cover-stack (rows animate as
        // each card covers).
        "(min-width: 768px) and (prefers-reduced-motion: no-preference)": () =>
          buildStandalone(section),
        // Mobile, motion OK → NO 3D pin; cards sit in normal flow (CSS flatten)
        // and each card's rows still animate in as it scrolls into view.
        "(max-width: 767px) and (prefers-reduced-motion: no-preference)": () =>
          buildFlat(section),
        // Reduced motion (any width) → nothing animates; the CSS keeps rows shown.
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
