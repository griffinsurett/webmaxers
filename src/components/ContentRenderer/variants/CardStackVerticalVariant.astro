---
// src/components/ContentRenderer/variants/CardStackVerticalVariant.astro
/**
 * Card Stack Vertical Variant — pinned "cover stack" card section.
 *
 * Card slides only (no intro / outro). Each slide is a real flex container with
 * two halves — media (left) and text (right) — divided by a real border. Slides
 * are absolutely stacked full-screen on one pin; each later slide sits at a
 * higher z-index. On scroll each slide slides UP from below (yPercent 100 → 0)
 * and COVERS the one before it (the homepage CurtainStack feel). No fade.
 *
 * Sequence (GSAP ScrollTrigger, self-pinned):
 *   - slide 0 rests full-screen.
 *   - each slide i ≥ 1 slides up to cover slide i-1 over ~1vh of scroll.
 *   - finally the whole section peels off the top (~1vh) to reveal what follows.
 *
 * Fallback: <768px / reduced-motion → static vertical stack, normal scroll.
 *
 * Layout is plain Tailwind on real containers — no absolute-overlay rules, no
 * :global hacks on the shared card — so it centres and restyles cleanly.
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import FilmstripCardMedia from "@/components/LoopComponents/FilmstripCardMedia.astro";
import Button from "@/components/Button/Button";

type Props = BaseVariantProps;

const { items = [], title = "", id, placeholderMedia = false } = Astro.props as Props & {
  placeholderMedia?: boolean;
};
---

<section
  id={id}
  class="csv-section relative h-screen w-full overflow-hidden border-y border-text/12"
  data-cardstack-v
  aria-label={title?.replace?.("\n", " ") ?? "Cards"}
>
  {items.map((item, i) => {
    const externalUrl = item.link?.url ?? item.projectUrl ?? item.url;
    const externalLabel = item.link?.label ?? "Visit ↗";
    const tags = [item.industry, ...(item.technologies ?? [])].filter(Boolean);
    // Alternate the background gradient direction per slide.
    const gradient = i % 2 === 0 ? "bg-linear-to-r" : "bg-linear-to-l";

    return (
      <article
        class:list={[
          "csv-slide absolute inset-0 flex h-full w-full items-stretch border border-text/12 from-bg3 to-bg",
          gradient,
        ]}
        data-cardstack-v-card
        data-slide-index={i + 1}
      >
        {/* The actual card: one full-width row, two equal halves, a real divider. */}
        <div class="grid h-full w-full grid-cols-1 md:grid-cols-2">
          {/* ── Media half (left) ── */}
          <div class="flex h-full min-h-0 items-center justify-center px-(--csv-half-pad) py-(--csv-half-pad)">
            <div class="aspect-[20/13] w-full max-w-[52rem] overflow-hidden">
              {placeholderMedia ? (
                <div class="h-full w-full bg-bg" aria-hidden="true"></div>
              ) : (
                <FilmstripCardMedia
                  title={item.title}
                  featuredVideo={item.featuredVideo}
                  fullSiteImage={item.fullSiteImage}
                  bannerImage={item.bannerImage}
                  featuredImage={item.featuredImage}
                />
              )}
            </div>
          </div>

          {/* ── Text half (right) — real left border = the divider ── */}
          <div class="flex h-full min-h-0 border-t border-text/12 px-(--csv-half-pad) py-(--csv-half-pad) md:border-l md:border-t-0 md:border-text/12">
            <div class="flex w-full flex-col justify-center gap-3 text-left md:max-w-[34rem]">
              <h3 class="text-base font-medium leading-tight text-heading">{item.title}</h3>

              {tags.length > 0 && (
                <p class="text-[0.65rem] uppercase tracking-[0.12em] text-text/45">
                  {tags.join(" · ")}
                </p>
              )}

              {item.description && (
                <p class="text-sm font-light leading-relaxed text-text/65">{item.description}</p>
              )}

              {i === 0 && <slot name="under-text" />}

              {externalUrl && (
                <Button
                  variant="underline"
                  href={externalUrl}
                  size="sm"
                  target="_blank"
                  rel="noopener noreferrer"
                  className="mt-1 self-start"
                  client:load
                >
                  {externalLabel}
                </Button>
              )}
            </div>
          </div>
        </div>
      </article>
    );
  })}
</section>

<style>
  /* Layout knobs only — everything visual is Tailwind on the markup above. */
  [data-cardstack-v] {
    --csv-half-pad: clamp(1.5rem, 3.5vw, 4rem);
  }

  @media (max-width: 767px) {
    [data-cardstack-v] {
      --csv-half-pad: clamp(1.25rem, 5vw, 2rem);
    }
  }

  .csv-slide { will-change: transform; }

  /* ── Reduced motion: static vertical stack, no pinning ───────── */
  @media (prefers-reduced-motion: reduce) {
    .csv-section { height: auto; overflow: visible; }
    .csv-slide {
      position: static;
      inset: auto;
      min-height: 60vh;
      transform: none !important;
      will-change: auto;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Cover-stack sequencer: slides are absolutely stacked; each later slide rises
  // up from below (yPercent 100 → 0) to cover the previous one, then the whole
  // section peels off the top. One pinned, scrubbed timeline drives it all.
  function buildStandalone(section: HTMLElement) {
    const slides = Array.from(
      section.querySelectorAll<HTMLElement>("[data-cardstack-v-card]"),
    );
    if (!slides.length) return;

    // Later slides sit on top; slide 0 rests in place, the rest wait below.
    slides.forEach((slide, i) => {
      slide.style.zIndex = String(i + 1);
      gsap.set(slide, { yPercent: i === 0 ? 0 : 100 });
    });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "+=" + window.innerHeight * slides.length,
        pin: true,
        scrub: true,
        anticipatePin: 1,
        invalidateOnRefresh: true,
      },
    });

    // Each slide after the first rises up to cover the previous one.
    for (let i = 1; i < slides.length; i++) {
      tl.to(slides[i], { yPercent: 0, ease: "none", duration: 1 }, ">");
    }

    // Finally, peel the whole section off the top to reveal what follows.
    tl.to(section, { yPercent: -100, ease: "none", duration: 1 }, ">");
  }

  function init() {
    const sections = document.querySelectorAll<HTMLElement>("[data-cardstack-v]");
    if (!sections.length) return;
    sections.forEach((section) => {
      ScrollTrigger.matchMedia({
        "(prefers-reduced-motion: no-preference)": () => buildStandalone(section),
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
