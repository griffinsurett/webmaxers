---
// src/components/ContentRenderer/variants/SolutionsDeckVariant.astro
import type { BaseVariantProps } from "../ContentRenderer.types";
import Icon from "@/components/Icon";
import WebsitesDemo from "@/components/AnimatedExamples/WebsitesDemo";
import BrandingDemo from "@/components/AnimatedExamples/BrandingDemo";
import AiAgentsDemo from "@/components/AnimatedExamples/AiAgentsDemo";

type Props = BaseVariantProps;

const { items = [], id, className = "" } = Astro.props as Props;

// Shared content padding — applied to the top row and the body so the card
// itself has no padding and the middle (future-content slot) runs edge-to-edge.
const PAD = "p-[clamp(0.875rem,1.2vw,1.125rem)]";
---

<section
  id={id}
  class:list={[
    "section-container flex flex-col justify-center min-h-[100svh] py-[clamp(4rem,8vh,6rem)]",
    className,
  ]}
  aria-label="Our solutions"
  data-solutions-deck
>
  <ul class="list-none grid grid-cols-1 md:grid-cols-3 gap-5 m-0 p-0">
    {
      items.map((item, i) => {
        const Tag = item.url ? "a" : "div";
        return (
          <li class="solutions-card" data-solutions-card style={`--sc-i:${i}`}>
            <Tag
              {...(item.url ? { href: item.url } : {})}
              class="group relative flex flex-col h-full min-h-[clamp(24rem,28vw,32rem)] rounded-[24px] overflow-hidden no-underline bg-bg3 border border-border shadow-[0_8px_30px_rgba(0,0,0,0.15)] transition-all duration-300 hover:border-border-strong hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(0,0,0,0.25)]"
            >
              {/* Top row: All-caps title (left) and indicators (right) */}
              <div class="flex items-center justify-between gap-4 px-6 pt-5 pb-3">
                <h3 class="text-[13px] font-bold uppercase tracking-[0.06em] text-heading">
                  {item.title}
                </h3>
                
                <div class="flex items-center gap-[3px] shrink-0" aria-hidden="true">
                  <div class={`w-[3px] h-[12px] rounded-full transition-colors duration-300 ${i === 0 ? 'bg-[#5e76f6] shadow-[0_0_8px_rgba(94,118,246,0.6)]' : 'dark:bg-white/10 light:bg-black/10'}`} />
                  <div class={`w-[3px] h-[12px] rounded-full transition-colors duration-300 ${i === 1 ? 'bg-[#0ea5e9] shadow-[0_0_8px_rgba(14,165,233,0.6)]' : 'dark:bg-white/10 light:bg-black/10'}`} />
                  <div class={`w-[3px] h-[12px] rounded-full transition-colors duration-300 ${i === 2 ? 'bg-[#4ade80] shadow-[0_0_8px_rgba(74,222,128,0.6)]' : 'dark:bg-white/10 light:bg-black/10'}`} />
                </div>
              </div>

              {/* Inset Canvas Container */}
              <div class="relative mx-5 my-1.5 rounded-[16px] overflow-hidden border border-border bg-[#0c0c0c] aspect-[360/260] shrink-0" aria-hidden="true">
                {/* Version Pill Overlay */}
                <span class="absolute top-3.5 left-3.5 z-10 px-2.5 py-[3px] rounded-full text-[9px] font-mono tracking-wider font-bold bg-[#141414]/80 border border-white/[0.08] text-white/40 uppercase backdrop-blur-md">
                  {item.id === "websites" && "v2.1 Web Architecture"}
                  {item.id === "branding" && "v2.1 Brand Core"}
                  {item.id === "ai-agents" && "v2.1 Behaviour Model"}
                </span>

                {/* Animated Demos */}
                <div class="h-full w-full pointer-events-none select-none">
                  {item.id === "websites" && <WebsitesDemo client:visible className="h-full w-full" />}
                  {item.id === "branding" && <BrandingDemo client:visible className="h-full w-full" />}
                  {item.id === "ai-agents" && <AiAgentsDemo client:visible className="h-full w-full" />}
                </div>
              </div>

              {/* Description pinned to the bottom */}
              <div class="mt-auto px-6 pb-6 pt-2">
                {item.description && (
                  <p class="text-[13.5px] font-light leading-[1.6] text-muted group-hover:text-heading transition-colors duration-300">
                    {item.description}
                  </p>
                )}
              </div>
            </Tag>
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  /* Cards start hidden + nudged down for motion-OK users so GSAP can reveal
     them on view (in AND out). Reduced-motion users see them immediately. */
  @media (prefers-reduced-motion: no-preference) {
    .solutions-card { opacity: 0; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Reveal the deck's cards as they scroll into view: each card fades + rises in,
  // staggered left→right; reverses (out) when it leaves, and replays on re-entry
  // in either direction. Per-section so multiple decks each animate their own.
  function initDeck() {
    const decks = document.querySelectorAll<HTMLElement>("[data-solutions-deck]");
    if (!decks.length) return;

    decks.forEach((deck) => {
      const cards = Array.from(
        deck.querySelectorAll<HTMLElement>("[data-solutions-card]"),
      );
      if (!cards.length) return;

      ScrollTrigger.matchMedia({
        "(prefers-reduced-motion: no-preference)": () => {
          gsap.set(cards, { autoAlpha: 0, y: 40 });

          const play = () =>
            gsap.to(cards, {
              autoAlpha: 1,
              y: 0,
              ease: "power3.out",
              duration: 0.7,
              stagger: 0.12,
              overwrite: true,
            });
          const hide = () =>
            gsap.set(cards, { autoAlpha: 0, y: 40, overwrite: true });

          ScrollTrigger.create({
            trigger: deck,
            start: "top 80%",
            end: "bottom 20%",
            onEnter: play,
            onEnterBack: play,
            onLeave: hide,
            onLeaveBack: hide,
          });
        },
      });
    });
  }

  initDeck();
  document.addEventListener("astro:page-load", initDeck);
</script>
