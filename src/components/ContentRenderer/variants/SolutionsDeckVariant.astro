---
// src/components/ContentRenderer/variants/SolutionsDeckVariant.astro
import type { BaseVariantProps } from "../ContentRenderer.types";
import Icon from "@/components/Icon";
import { related } from "@/utils/query";

type Props = BaseVariantProps;

const { items = [], id, className = "" } = Astro.props as Props;

// Related services for each solution: capabilities whose `solutions` ref points
// at this solution. Drives the service pills shown inside each card (replacing
// the old animated demos) — fully content-driven, no hardcoded lists.
const servicesBySolution = new Map<string, string[]>(
  await Promise.all(
    items.map(async (item) => {
      const caps = await related("capabilities", "solutions", item.id).all();
      return [item.id, caps.map((c: any) => c.data.title as string)] as const;
    }),
  ),
);

// Shared content padding — applied to the top row and the body so the card
// itself has no padding and the middle (services slot) runs edge-to-edge.
const PAD = "p-[clamp(0.875rem,1.2vw,1.125rem)]";
---

<section
  id={id}
  class:list={[
    "section-container flex flex-col justify-center min-h-[100svh] py-[clamp(4rem,8vh,6rem)]",
    className,
  ]}
  aria-label="Our solutions"
  data-solutions-deck
>
  <ul class="list-none grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5 m-0 p-0">
    {
      items.map((item, i) => {
        const Tag = item.url ? "a" : "div";
        return (
          <li class="solutions-card" data-solutions-card style={`--sc-i:${i}`}>
            <Tag
              {...(item.url ? { href: item.url } : {})}
              class="group relative flex flex-col h-full min-h-[clamp(22rem,26vw,30rem)] rounded-lg overflow-hidden no-underline bg-bg3 border border-heading/8 [transition:transform_200ms_ease,border-color_200ms_ease] hover:border-heading/18 hover:-translate-y-0.5"
            >
              {/* Top row: icon + title (left) inline with the circular arrow (right) */}
              <div class={`flex items-center justify-between gap-4 ${PAD}`}>
                <div class="flex items-center gap-3 min-w-0">
                  {item.icon && (
                    <span class="inline-flex shrink-0 text-heading/45">
                      <Icon icon={item.icon} size="lg" />
                    </span>
                  )}
                  <h3 class="text-[clamp(1.25rem,1.6vw,1.5rem)] font-normal leading-[1.1] tracking-[-0.02em] text-heading">
                    {item.title}
                  </h3>
                </div>
                <span
                  class="inline-flex items-center justify-center shrink-0 w-7 h-7 rounded-full text-heading/35 border border-heading/10 transition-[color,border-color,transform] duration-200 group-hover:text-heading group-hover:border-heading/30 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  aria-hidden="true"
                >
                  <svg viewBox="0 0 24 24" fill="none" width="15" height="15">
                    <path
                      d="M7 17L17 7M17 7H8M17 7V16"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </div>

              {/* Middle slot — the solution's related services as pills. Each
                  pill is a capability whose `solutions` ref points at this
                  solution (content-driven, queried above). */}
              <div class={`flex-1 ${PAD} pt-0`}>
                {(servicesBySolution.get(item.id) ?? []).length > 0 && (
                  <ul class="list-none flex flex-wrap gap-2 m-0 p-0">
                    {(servicesBySolution.get(item.id) ?? []).map((service) => (
                      <li class="inline-flex items-center rounded-full bg-bg border border-heading/10 px-3 py-1.5 text-[clamp(0.8125rem,0.95vw,0.875rem)] leading-none font-light text-heading/75">
                        {service}
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              {/* Description pinned to the bottom */}
              <div class={`flex flex-col gap-2.5 ${PAD}`}>
                {item.description && (
                  <p class="text-[clamp(0.875rem,1vw,0.9375rem)] font-light leading-[1.7] text-heading/42">
                    {item.description}
                  </p>
                )}
              </div>
            </Tag>
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  /* Cards start hidden + nudged down for motion-OK users so GSAP can reveal
     them on view (in AND out). Reduced-motion users see them immediately. */
  @media (prefers-reduced-motion: no-preference) {
    .solutions-card { opacity: 0; }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Reveal the deck's cards as they scroll into view: each card fades + rises in,
  // staggered left→right; reverses (out) when it leaves, and replays on re-entry
  // in either direction. Per-section so multiple decks each animate their own.
  function initDeck() {
    const decks = document.querySelectorAll<HTMLElement>("[data-solutions-deck]");
    if (!decks.length) return;

    decks.forEach((deck) => {
      const cards = Array.from(
        deck.querySelectorAll<HTMLElement>("[data-solutions-card]"),
      );
      if (!cards.length) return;

      ScrollTrigger.matchMedia({
        "(prefers-reduced-motion: no-preference)": () => {
          gsap.set(cards, { autoAlpha: 0, y: 40 });

          const play = () =>
            gsap.to(cards, {
              autoAlpha: 1,
              y: 0,
              ease: "power3.out",
              duration: 0.7,
              stagger: 0.12,
              overwrite: true,
            });
          const hide = () =>
            gsap.set(cards, { autoAlpha: 0, y: 40, overwrite: true });

          ScrollTrigger.create({
            trigger: deck,
            start: "top 80%",
            end: "bottom 20%",
            onEnter: play,
            onEnterBack: play,
            onLeave: hide,
            onLeaveBack: hide,
          });
        },
      });
    });
  }

  initDeck();
  document.addEventListener("astro:page-load", initDeck);
</script>
