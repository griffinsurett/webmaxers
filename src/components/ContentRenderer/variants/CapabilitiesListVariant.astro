---
import type { BaseVariantProps } from "../ContentRenderer.types";

const {
  items = [],
  id,
  className = "",
} = Astro.props as BaseVariantProps;

const listItems = items
  .map((item: any) => ({
    title: item?.title ?? "",
    url: item?.url ?? item?.link?.url ?? "",
  }))
  .filter((item) => item.title);
---

<ul id={id} class={`capabilities-list ${className}`} role="list">
  {listItems.map((item, i) => {
    const Tag = item.url ? "a" : "div";
    return (
      <li class="capabilities-list-item" style={`--cap-delay:${i * 0.06}s`}>
        <Tag
          {...(item.url ? { href: item.url } : {})}
          class="capabilities-list-row reveal-item"
        >
          <span class="capabilities-list-name">{item.title}</span>
          <span class="capabilities-list-arrow" aria-hidden="true">
            ↗
          </span>
        </Tag>
      </li>
    );
  })}
</ul>

<style>
  .capabilities-list {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    border-top: 1px solid color-mix(in srgb, var(--color-heading) 18%, transparent);
  }

  .capabilities-list-item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-heading) 18%, transparent);
  }

  .capabilities-list-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(1rem, 2vw, 1.4rem) 0;
    text-decoration: none;
    color: inherit;
  }

  .capabilities-list-name {
    font-size: clamp(1.1rem, 1.9vw, 1.45rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    color: var(--color-heading);
  }

  .capabilities-list-arrow {
    font-size: 1.05rem;
    line-height: 1;
    color: color-mix(in srgb, var(--color-text) 45%, transparent);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .capabilities-list-row:hover .capabilities-list-arrow {
    transform: translate(2px, -2px);
    color: var(--color-heading);
  }

  .capabilities-list-row:focus-visible {
    outline: none;
  }

  .capabilities-list-row:focus-visible .capabilities-list-arrow {
    color: var(--color-heading);
  }

  @media (prefers-reduced-motion: reduce) {
    .capabilities-list-arrow {
      transition: none;
    }
  }
</style>
