---
// src/components/Portfolio/PortfolioSectionVertical.astro
// Vertical-scroll twin of PortfolioSection.astro — same card stack shell,
// now driven by the Websites capability set and rendered through
// CardStackVerticalVariant (half-and-half cards glide bottom→top, then the
// whole section peels off the top to reveal what follows).
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { children } from "@/utils/query/snippets";

interface Props {
  heading?: string;
  ctaLink?: string;
  placeholderMedia?: boolean;
}

const { heading = "Capabilities", ctaLink, placeholderMedia = false } = Astro.props;

// The child capabilities under the "websites" parent (Performance Optimization,
// Website Design, …) — one card each. We deliberately query the children, NOT
// related(…), so the parent "Website Capabilities" index entry is excluded.
const websiteCapabilities = children("capabilities", "websites");
---

<ContentRenderer
  id="portfolio-filmstrip-vertical-section"
  query={websiteCapabilities}
  variant="CardStackVerticalVariant"
  title={heading}
  collectionUrl={ctaLink}
  placeholderMedia={placeholderMedia}
/>
