---
// src/components/Starfield/Starfield.astro
/**
 * Starfield — dark-mode space background, built the Astro way:
 *
 *   1. STATIC PLACEHOLDER — a pure-CSS star field (this markup) renders
 *      server-side and shows INSTANTLY. Zero JS, no twinkle, no movement.
 *   2. ANIMATED CANVAS — a React island (StarfieldCanvas) hydrated `client:idle`,
 *      so the canvas + animation loop only spin up once the browser is idle,
 *      then crossfade in OVER the placeholder (twinkle + shooting stars).
 *
 * Mirrors the image/Lottie deferral pattern: a believable starfield paints on
 * the critical path with no JS, and the motion layers in on idle.
 *
 * Dark-mode only (hidden in light mode). The island reads useMotionPreference()
 * so reduced motion (live toggle / OS) keeps it to the calm CSS placeholder.
 *
 * `class` places / z-indexes the root.
 */
import StarfieldCanvas from "./StarfieldCanvas.tsx";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class:list={["starfield-root", className]} aria-hidden="true">
  {/* Instant, no-JS placeholder: calm CSS stars on the page bg. */}
  <div class="starfield-static"></div>
  {/* Animated overlay — hydrates + starts only when the browser is idle. */}
  <StarfieldCanvas client:idle />
</div>

<style>
  /* Dark-mode only: the field IS the dark background. Hidden in light mode so
     the normal light page bg shows. Fixed so it stays put while content scrolls
     over it; pointer-events off so it never blocks interaction. */
  .starfield-root {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: var(--color-bg);
  }
  :global([data-theme="light"]) .starfield-root {
    display: none;
  }

  .starfield-static,
  :global(.starfield-canvas) {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Pure-CSS static star field: layered radial-gradient "dots" tiled across the
     viewport. Calm, even, no animation — the instant placeholder. */
  .starfield-static {
    background-color: var(--color-bg);
    background-image:
      radial-gradient(1.2px 1.2px at 20% 30%, rgba(255, 255, 255, 0.85) 50%, transparent 52%),
      radial-gradient(1px 1px at 70% 20%, rgba(255, 255, 255, 0.7) 50%, transparent 52%),
      radial-gradient(1.4px 1.4px at 40% 70%, rgba(255, 255, 255, 0.8) 50%, transparent 52%),
      radial-gradient(1px 1px at 85% 60%, rgba(255, 255, 255, 0.6) 50%, transparent 52%),
      radial-gradient(1.1px 1.1px at 55% 45%, rgba(255, 255, 255, 0.75) 50%, transparent 52%),
      radial-gradient(0.9px 0.9px at 10% 80%, rgba(255, 255, 255, 0.6) 50%, transparent 52%),
      radial-gradient(1.3px 1.3px at 90% 90%, rgba(255, 255, 255, 0.7) 50%, transparent 52%),
      radial-gradient(1px 1px at 30% 15%, rgba(255, 255, 255, 0.65) 50%, transparent 52%);
    background-repeat: repeat;
    background-size: 320px 320px, 280px 280px, 360px 360px, 300px 300px,
      340px 340px, 260px 260px, 380px 380px, 290px 290px;
  }
</style>
