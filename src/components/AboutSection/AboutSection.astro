---
import { splitTextIntoAnimatedWords } from "@/utils/animatedText";
import LogoMark from "@/components/Logo/LogoMark.astro";
import Button from "@/components/Button/Button";
import EyebrowSection from "@/layouts/EyebrowSection.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import Video from "@/components/Video/Video.astro";
import { Image } from "astro:assets";
import aboutPortraitBw from "@/assets/about_portrait_bw.png";
import { query, sortByOrder } from "@/utils/query";
import { siteData } from "@/content/siteData";

// The AI explainer video (self-hosted in /public). Used as the About section's
// default video "for now". Being local, Video.astro auto-generates its optimized
// poster at build time (ffmpeg) — no manual thumbnail needed.
const AI_VIDEO_SRC =
  "/The_Ghost_Shift__Scaling_Beyond_the_Human_Ceiling_c1uefq.mp4";

interface Props {
  eyebrow?: string;
  statement?: string;
  leftText?: string;
  rightText?: string;
  ctaText?: string;
  ctaLink?: string;
  stickyHeight?: string;
  logoSize?: number;
  videoSrc?: string;
  videoPoster?: string;
  videoAlt?: string;
  videoWrapperClass?: string;
  videoClass?: string;
  /** Show the `stats` counters (bottom-left on desktop). */
  showStats?: boolean;
}

const {
  eyebrow = "About",
  statement = `${siteData.title} is an independent digital studio crafting meaningful brand experiences through strategy, design, and technology.`,
  leftText = "We design for longevity, clarity first, craft always, built to scale.",
  rightText = "Our mission is to make technology feel human by designing digital products that are intuitive, purposeful, and meaningful to people.",
  ctaText = "Explore Our Story",
  ctaLink = "/about-us",
  stickyHeight = "250svh",
  logoSize = 56,
  videoSrc,
  videoPoster,
  videoAlt = "About section video",
  videoWrapperClass = "",
  videoClass = "",
  showStats = false,
} = Astro.props;

const words = splitTextIntoAnimatedWords(statement);
---

<div class="flex flex-col gap-24 md:gap-36 lg:gap-48">

  <!-- Sticky scroll statement -->
  <aside
    class="about-sticky-section section-container"
    aria-label="About statement"
    data-about-sticky="true"
    style={`--about-section-height:${stickyHeight};`}
  >
    <div class:list={["about-sticky-pin", showStats && "about-sticky-pin--with-stats"]} data-about-sticky-inner>
      <section class="relative w-full">
        <EyebrowSection eyebrow={eyebrow}>
          <!-- Animated statement -->
          <h2
            class="about-statement max-w-4xl text-[clamp(1.75rem,7vw,4.5rem)] font-light leading-[1.1]"
            aria-label={statement}
          >
            {words.map((word) => (
              <>
                <span
                  class="about-word"
                  aria-hidden="true"
                  data-about-word-progress
                >
                  <span class="about-word-layer about-word-layer--base">{word.word}</span>
                  <span class="about-word-layer about-word-layer--overlay">{word.word}</span>
                </span>
                {!word.isLast && <span class="about-space" aria-hidden="true"> </span>}
              </>
            ))}
          </h2>
        </EyebrowSection>

        {/* Animated stat counters — absolutely pinned to the BOTTOM-LEFT of the
            frame, aligned to the same inset as the "About" eyebrow label. */}
        {showStats && (
          <ContentRenderer
            id="about-metrics-section"
            query={query("stats").orderBy(sortByOrder())}
            variant="StatsVariant"
            className="about-stats"
          />
        )}

        {/* Optimized portrait — pinned to the BOTTOM-RIGHT of the frame, mirroring
            the bottom-left stats. Optimized at build via astro:assets (webp). */}
        {showStats && (
          <Image
            src={aboutPortraitBw}
            alt=""
            width={420}
            densities={[1, 2]}
            format="webp"
            quality={72}
            loading="lazy"
            decoding="async"
            class="about-portrait"
          />
        )}
      </section>
    </div>
  </aside>

  <!-- Rolling logo divider -->
  <div class="about-roll-shell relative overflow-visible" aria-hidden="true">
    <div class="about-roll-track pointer-events-none absolute top-0 left-0 w-full overflow-visible">
      <!-- about-roll-bounce: travel + entry drop -->
      <!-- about-roll-spin: scroll-linked rotation wrapper around LogoMark -->
      <span class="about-roll-bounce">
        <span class="about-roll-spin">
          <LogoMark size={logoSize} loading="lazy" />
        </span>
      </span>
    </div>
  </div>

  <!-- About Bottom Section -->
  <section class="about-bottom section-container">
    <!-- Mobile: single column stack. md+: leftText | video | rightText+CTA -->
    <div class="grid grid-cols-1 gap-10 md:gap-12 lg:gap-16 md:grid-cols-[1fr_2fr_1fr] items-center">
      <p class="text-base font-light leading-relaxed text-text">
        {leftText}
      </p>
      <div class="flex items-center justify-center">
        <Video
          src={videoSrc ?? AI_VIDEO_SRC}
          poster={videoPoster}
          alt={videoAlt}
          wrapperClass={`about-video-shell !h-auto aspect-video overflow-hidden bg-black ${videoWrapperClass}`.trim()}
          class={`about-video-media ${videoClass}`.trim()}
          autoplay={false}
          muted={true}
          loop={true}
          controls={true}
          playsinline={true}
          lazy={false}
        />
      </div>
      <div class="flex flex-col justify-between gap-8">
        <p class="text-base font-light leading-relaxed text-text">
          {rightText}
        </p>
        <Button variant="underline" href={ctaLink} client:load>
          {ctaText}
        </Button>
      </div>
    </div>
  </section>
</div>

<style>
  .about-sticky-section {
    min-height: var(--about-section-height);
    position: relative;
  }

  .about-sticky-pin {
    --about-pin-top: clamp(5rem, 7vw, 7rem);
    position: sticky;
    top: var(--about-pin-top);
    width: 100%;
  }

  /* When the stats are shown, the pinned frame fills the visible viewport so the
     stats can anchor to its BOTTOM (the frame is 100vh minus the top offset). A
     definite height (not just min-height) lets the inner section resolve 100%. */
  .about-sticky-pin--with-stats {
    height: calc(100svh - var(--about-pin-top) - 1.5rem);
  }
  .about-sticky-pin--with-stats > section {
    height: 100%;
  }

  /* Mobile: cap the frame to 95svh so its bottom edge (where the stats + portrait
     pin) rises ABOVE the fixed "Ask a question" chat bar instead of sitting
     behind it. Below lg only — desktop has the 3-corner layout with room. */
  @media (max-width: 1023px) {
    .about-sticky-pin--with-stats {
      height: calc(95svh - var(--about-pin-top) - 1.5rem);
    }
  }

  /* Stat counters: absolutely pinned to the bottom-left of the frame, aligned to
     the same inset as the "About" eyebrow label (the section-container edge). */
  :global(.about-stats) {
    position: absolute;
    left: 0;
    bottom: 0;
  }


  /* Portrait, pinned inside the about frame. Mobile (default): bottom-LEFT and
     lifted to sit directly ABOVE the stats (vertical stack — image, then stats,
     then the fixed chat bar). Desktop (lg+): bottom-RIGHT corner, mirroring the
     bottom-left stats. Square source → height auto-derives from width. */
  .about-portrait {
    position: absolute;
    left: 0;
    /* Sit just above the bottom-left stats block (~stats height + gap). */
    bottom: 5.5rem;
    width: clamp(7rem, 32vw, 11rem);
    height: auto;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }
  @media (min-width: 1024px) {
    .about-portrait {
      left: auto;
      right: 0;
      bottom: 0;
      width: clamp(10rem, 16vw, 16rem);
    }
  }

  .about-statement {
    color: var(--color-heading);
    line-height: 1.08;
    text-wrap: balance;
    width: 100%;
  }

  .about-word {
    --word-progress: 0;
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }

  .about-word-layer {
    display: block;
  }

  .about-word-layer--base {
    /* dim colour: blend heading toward transparent */
    color: color-mix(in srgb, var(--color-heading) 12%, transparent);
  }

  .about-word-layer--overlay {
    position: absolute;
    inset: 0;
    color: var(--color-heading);
    pointer-events: none;
    opacity: var(--word-progress);
    will-change: opacity;
  }

  .about-space {
    white-space: pre;
  }

  .about-video-shell {
    width: 100%;
    /* Fills the center column; capped so it doesn't get unwieldy on very wide
       viewports. aspect-video (16:9) is set via the wrapperClass. */
    max-width: min(100%, 40rem);
    border-radius: 0;
  }

  .about-video-media {
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-sticky-section {
      min-height: auto;
    }
    .about-sticky-pin {
      position: static;
      min-height: auto;
      padding-block: 0;
    }
    /* No pinned frame to anchor to — stats return to normal flow under the text. */
    :global(.about-stats) {
      position: static;
      margin-top: clamp(1.5rem, 4vw, 3rem);
    }
    /* No pinned frame to anchor to — hide the corner portrait. */
    .about-portrait {
      display: none;
    }
    .about-word-layer--overlay {
      opacity: 1;
      will-change: auto;
    }
  }
  /* Same static fallback for the in-app accessibility reduced-motion toggle. */
  :global([data-a11y-motion="reduced"]) .about-sticky-section {
    min-height: auto;
  }
  :global([data-a11y-motion="reduced"]) .about-sticky-pin {
    position: static;
    min-height: auto;
    padding-block: 0;
  }
  :global([data-a11y-motion="reduced"]) .about-stats {
    position: static;
    margin-top: clamp(1.5rem, 4vw, 3rem);
  }
  :global([data-a11y-motion="reduced"]) .about-portrait {
    display: none;
  }
  :global([data-a11y-motion="reduced"]) .about-word-layer--overlay {
    opacity: 1;
    will-change: auto;
  }

  /* ── Rolling logo divider ── */
  .about-roll-shell {
    view-timeline-name: --about-roll;
    view-timeline-axis: block;
  }

  /* Bounce wrapper: positioned along the line, handles horizontal travel + entry drop */
  .about-roll-bounce {
    position: absolute;
    top: 50%;
    left: -3rem;
    display: block;
    transform: translateX(-50%) translateY(-50%);
    /* Entry bounce — fires once on first paint */
    animation: about-logo-bounce 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.1s;
  }

  /* Spin wrapper: only rotates, scroll-linked */
  .about-roll-spin {
    display: block;
    transform: rotate(0deg);
    will-change: transform;
  }

  @supports (animation-timeline: view()) {
    .about-roll-bounce {
      animation:
        about-logo-bounce 0.9s cubic-bezier(0.22, 1, 0.36, 1) both 0.1s,
        about-logo-travel linear both;
      animation-timeline: auto, --about-roll;
      animation-range: auto, entry 0% cover 100%;
    }

    .about-roll-spin {
      animation: about-logo-spin linear both;
      animation-timeline: --about-roll;
      animation-range: entry 0% cover 100%;
    }
  }

  @keyframes about-logo-bounce {
    0%   { transform: translateX(-50%) translateY(calc(-50% - 220px)) scaleY(1.1) scaleX(0.9); }
    55%  { transform: translateX(-50%) translateY(-50%) scaleY(0.7)  scaleX(1.25); }
    70%  { transform: translateX(-50%) translateY(calc(-50% - 40px))  scaleY(1.05) scaleX(0.97); }
    82%  { transform: translateX(-50%) translateY(-50%) scaleY(0.88) scaleX(1.1); }
    91%  { transform: translateX(-50%) translateY(calc(-50% - 12px))  scaleY(1)   scaleX(1); }
    100% { transform: translateX(-50%) translateY(-50%) scaleY(1)    scaleX(1); }
  }

  @keyframes about-logo-travel {
    from { left: -3rem; }
    to   { left: calc(100% + 3rem); }
  }

  @keyframes about-logo-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(1440deg); }
  }

  /* Reduced motion (OS preference OR the in-app accessibility toggle): hide the
     rolling logo divider entirely. */
  @media (prefers-reduced-motion: reduce) {
    .about-roll-bounce {
      display: none;
    }
  }
  :global([data-a11y-motion="reduced"]) .about-roll-bounce {
    display: none;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { readMotionPreference } from "@/hooks/useMotionPreference";
  gsap.registerPlugin(ScrollTrigger);

  function init() {
    const sections = document.querySelectorAll<HTMLElement>("[data-about-sticky='true']");
    if (!sections.length) return;

    sections.forEach((section) => {
      const words = section.querySelectorAll<HTMLElement>("[data-about-word-progress]");
      if (!words.length) return;

      // Reduced motion (OS preference OR in-app accessibility toggle): show the
      // statement fully revealed and skip the scroll-driven reveal entirely.
      if (readMotionPreference()) {
        words.forEach((w) => w.style.setProperty("--word-progress", "1"));
        return;
      }

      ScrollTrigger.create({
        trigger: section,
        start: "top top",
        end: "bottom bottom",
        onUpdate(self) {
          const total = words.length || 1;
          words.forEach((node, i) => {
            const wp = Math.max(0, Math.min(self.progress * total - i, 1));
            node.style.setProperty("--word-progress", wp.toFixed(4));
          });
        },
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
