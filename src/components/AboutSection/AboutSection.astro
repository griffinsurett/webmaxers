---
import ScrollRevealText from "@/components/ScrollRevealText/ScrollRevealText.astro";

interface Props {
  headline?: string;
  subheadline?: string;
  statement?: string;
  ctaText?: string;
  ctaLink?: string;
  className?: string;
}

const {
  headline = "About Us",
  subheadline = "Our Story",
  statement = "We are dedicated to providing exceptional digital solutions that drive real results. With years of expertise and a passion for innovation, we partner with visionary companies to build digital experiences that matter. Our commitment is unwavering: deliver measurable impact through strategic thinking, technical excellence, and relentless attention to detail.",
  ctaText = "Learn More",
  ctaLink = "/about-us",
  className = "",
} = Astro.props;
---

<section class={`relative py-20 md:py-32 px-6 md:px-12 ${className}`}>
  <div class="max-w-5xl mx-auto">
    <!-- Subheadline -->
    <div class="mb-6 md:mb-8">
      <p class="text-sm md:text-base uppercase tracking-widest text-gray-500 font-light">
        {subheadline}
      </p>
    </div>

    <!-- Main Headline -->
    <h2 class="text-5xl md:text-7xl font-light leading-tight mb-12 md:mb-16 text-white">
      {headline}
    </h2>

    <!-- About Statement with Scroll Reveal -->
    <div class="relative mb-12 md:mb-16">
      <p class="text-xl md:text-2xl lg:text-3xl font-light leading-relaxed md:leading-relaxed lg:leading-relaxed text-gray-600">
        <ScrollRevealText
          text={statement}
          splitType="word"
          className="text-inherit"
        />
      </p>

      <!-- Decorative accent line -->
      <div class="absolute -left-6 md:-left-12 top-0 bottom-0 w-1 bg-gradient-to-b from-transparent via-gray-700 to-transparent opacity-40"></div>
    </div>

    <!-- CTA Button -->
    <div class="flex items-center gap-6">
      <a
        href={ctaLink}
        class="group inline-flex items-center px-8 py-3 bg-white text-black font-light uppercase tracking-widest text-sm transition-all hover:bg-gray-200 active:scale-95"
      >
        {ctaText}
        <span class="ml-2 inline-block transition-transform group-hover:translate-x-1">→</span>
      </a>

      <!-- Divider -->
      <div class="hidden sm:block h-12 w-px bg-gradient-to-b from-transparent via-gray-700 to-transparent opacity-40"></div>

      <!-- Stats or additional info -->
      <div class="hidden sm:block">
        <div class="text-gray-400 text-sm uppercase tracking-widest font-light">
          <span class="text-white font-semibold">Proven</span> Results
        </div>
      </div>
    </div>
  </div>

  <!-- Background grid accent (subtle) -->
  <div class="absolute inset-0 pointer-events-none opacity-5">
    <div class="absolute inset-0 bg-grid-small [background-image:linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(180deg,rgba(255,255,255,.1)_1px,transparent_1px)] [background-size:50px_50px]"></div>
  </div>
</section>

<style>
  .bg-grid-small {
    background-size: 50px 50px;
  }
</style>
