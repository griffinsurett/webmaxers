---
import { splitIntoWords } from '@/utils/letterByLetter';

interface Props {
  statement?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  statement = "Webmaxers is an independent digital studio crafting meaningful brand experiences through strategy, design, and technology.",
  ctaText = "Explore Our Story",
  ctaLink = "/about-us",
} = Astro.props;

const words = splitIntoWords(statement, { staggerDelay: 25 });
const totalDuration = statement.replace(/\s/g, '').length * 25;
---

<div id="scroll-reveal-about">
  <div id="scroll-reveal-trigger" style="height: 100vh; pointer-events: none;"></div>

  <section
    id="scroll-reveal-container"
    class="relative w-full py-20 md:py-32 px-6 md:px-[80px]"
  >
    <div class="flex gap-12 md:gap-16 w-full">
      <!-- Left: Title -->
      <div class="shrink-0">
        <h2 class="text-lg font-light tracking-widest uppercase text-zinc-400">
          About
        </h2>
      </div>

      <!-- Right: Statement and CTA -->
      <div class="flex-1 max-w-4xl">
        <p
          id="scroll-reveal-text"
          class="text-[clamp(2.5rem,7vw,4.5rem)] font-light leading-[1.1] text-white mb-12 md:mb-16"
        >
          {words.map((wordGroup) => (
            wordGroup.wordIndex === -1 ? (
              <span key={`space-${wordGroup.word}`} class="word-space">{wordGroup.word}</span>
            ) : (
              <span key={`word-${wordGroup.wordIndex}`} class="word inline-block">
                {wordGroup.letters.map((letter) => (
                  <span
                    key={`letter-${letter.index}`}
                    data-letter-index={letter.index}
                    class="letter inline-block"
                    style={{
                      opacity: '0.1',
                      color: 'rgb(255, 255, 255)',
                      willChange: 'opacity',
                    }}
                  >
                    {letter.char}
                  </span>
                ))}
              </span>
            )
          ))}
        </p>

        <a
          href={ctaLink}
          class="group inline-flex items-center justify-between gap-8 text-[11px] font-medium tracking-[0.18em] uppercase text-zinc-400 border-b border-zinc-400 pb-[6px] hover:text-white hover:border-white transition-colors duration-200"
        >
          {ctaText}
          <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Spacer for scroll distance -->
  <div style={`height: ${totalDuration}px`}></div>
</div>

<script is:inline define:vars={{ totalDuration }}>
  (function initScrollReveal() {
    const container = document.getElementById('scroll-reveal-container');
    const trigger = document.getElementById('scroll-reveal-trigger');
    const textElement = document.getElementById('scroll-reveal-text');

    if (!container || !trigger || !textElement) return;

    let isAnimating = false;
    let letterSpans = null;

    function handleScroll() {
      const triggerRect = trigger.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      const triggerCenter = triggerRect.top + triggerRect.height / 2;
      const startPoint = windowHeight;
      const endPoint = -triggerRect.height;

      let progress = (startPoint - triggerCenter) / (startPoint - endPoint);
      progress = Math.max(0, Math.min(1, progress));

      const animating = progress > 0 && progress < 1;

      if (animating !== isAnimating) {
        isAnimating = animating;
        if (isAnimating) {
          container.style.position = 'sticky';
          container.style.top = '0';
          container.style.zIndex = '40';
          container.style.height = '100vh';
          container.style.display = 'flex';
          container.style.alignItems = 'center';
        } else {
          container.style.position = 'relative';
          container.style.top = 'auto';
          container.style.zIndex = 'auto';
          container.style.height = 'auto';
          container.style.display = 'block';
        }
      }

      if (!letterSpans) {
        letterSpans = textElement.querySelectorAll('[data-letter-index]');
      }

      letterSpans.forEach((span) => {
        const letterIndex = parseInt(span.getAttribute('data-letter-index'), 10);
        const letterDelay = letterIndex * 25;
        const letterProgress = (progress * totalDuration - letterDelay) / (totalDuration * 0.6);
        const opacity = Math.max(0, Math.min(1, letterProgress));
        span.style.opacity = String(opacity);
      });
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  })();
</script>
