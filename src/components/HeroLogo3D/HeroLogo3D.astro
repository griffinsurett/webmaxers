---
// src/components/HeroLogo3D/HeroLogo3D.astro
/**
 * HeroLogo3D — thin Astro wrapper around the React island. Hydrates with
 * `client:idle`, so the heavy Three.js + GLB load once the browser is idle after
 * load (not on the critical path). The island renders the poster (slot)
 * immediately; reduced-motion keeps the poster forever and never loads the 3D.
 *
 * Positioning is yours via `class`. The break scrubs across `breakSelector`.
 */
import HeroLogo3DIsland from "./HeroLogo3D.tsx";

interface Props {
  class?: string;
  breakSelector?: string;
}

const { class: className = "", breakSelector } = Astro.props;
---

<HeroLogo3DIsland
  className={className}
  breakSelector={breakSelector}
  client:idle
>
  <slot />
</HeroLogo3DIsland>
