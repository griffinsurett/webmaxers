---
import LottieLogo from "./LottieLogo";
import LogoMark from "./LogoMark.astro";
import TextLogoStatic from "./TextLogoStatic.astro";
import { siteData } from "@/content/siteData";

export interface Props {
  loading?: "lazy" | "eager";
  trigger?: "auto" | "scroll" | "visible" | "load";
  hydrate?: "load" | "idle" | "visible" | "scroll";
  textFadeMs?: number;
  animateOutText?: boolean;
  class?: string;
  useLottie?: boolean;
  showText?: boolean;
  size?: number;
  titleFirstClass?: string;
  titleRestClass?: string;
  loop?: boolean;
  autoplay?: boolean;
  altContext?: string;
}

const {
  loading = "eager",
  trigger = "auto",
  hydrate,
  textFadeMs = 1200,
  animateOutText = false,
  class: className = "",
  useLottie = true,
  showText = true,
  size = 40,
  titleFirstClass,
  titleRestClass,
  loop = true,
  autoplay = false,
  altContext,
} = Astro.props;

const alt = altContext ? `Web Maxers Logo - ${altContext}` : "Web Maxers Logo";

const shouldUseLottie =
  useLottie && (trigger === "scroll" || trigger === "visible" || trigger === "load");

const hydrationMode =
  hydrate ?? (trigger === "scroll" ? "scroll" : trigger === "visible" ? "visible" : "load");

// Lottie container gets [filter:none] — the parent span carries the invert via logo-class
const lottieClassName = "[filter:none]";
// Rendered size is responsive (smaller on mobile, full `size` from sm: up); the
// underlying <Image> still loads at `size` px for a crisp asset.
const mediaClasses = `block w-8 h-8 sm:w-[${size}px] sm:h-[${size}px] object-contain animate-spin-once`;
---

<a
  href="/"
  translate="no"
  class={`notranslate flex justify-center items-center gap-1.5 ${className}`}
>
  {/* logo-class wrapper: invert(1) in light mode only, via @custom-variant light */}
  <span class="logo-class">
    {shouldUseLottie ? (
      hydrationMode === "scroll" ? (
        <LottieLogo alt={alt} loading={loading} trigger={trigger} className={lottieClassName} mediaClasses={mediaClasses} loop={loop} autoplay={autoplay} client:scroll>
          <LogoMark size={size} loading={loading} invert={false} imgClass={mediaClasses} />
        </LottieLogo>
      ) : hydrationMode === "visible" ? (
        <LottieLogo alt={alt} loading={loading} trigger={trigger} className={lottieClassName} mediaClasses={mediaClasses} loop={loop} autoplay={autoplay} client:visible>
          <LogoMark size={size} loading={loading} invert={false} imgClass={mediaClasses} />
        </LottieLogo>
      ) : hydrationMode === "idle" ? (
        <LottieLogo alt={alt} loading={loading} trigger={trigger} className={lottieClassName} mediaClasses={mediaClasses} loop={loop} autoplay={autoplay} client:idle>
          <LogoMark size={size} loading={loading} invert={false} imgClass={mediaClasses} />
        </LottieLogo>
      ) : (
        <LottieLogo alt={alt} loading={loading} trigger={trigger} className={lottieClassName} mediaClasses={mediaClasses} loop={loop} autoplay={autoplay} client:load>
          <LogoMark size={size} loading={loading} invert={false} imgClass={mediaClasses} />
        </LottieLogo>
      )
    ) : (
      <LogoMark size={size} loading={loading} invert={false} imgClass={mediaClasses} />
    )}
  </span>

  {showText && (
    <div>
      <TextLogoStatic
        title={siteData.title}
        className="flex flex-row items-baseline gap-1 p-0 m-0"
        fadeDuration={textFadeMs}
        animateOutText={animateOutText}
        firstClass={titleFirstClass}
        restClass={titleRestClass}
      />
    </div>
  )}
</a>
