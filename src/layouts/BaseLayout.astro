---
// src/layouts/BaseLayout.astro
/**
 * Base Layout - Root HTML Structure
 *
 * The foundation layout for all pages in the application.
 * Provides:
 * - HTML document structure
 * - Head section with meta tags, SEO, theme setup
 * - Fixed site header (always rendered, pinned over the page)
 * - A per-page hero slot, the main content slot, and the footer
 * - Global styles import
 *
 * Structure:
 *   <body>
 *     <div id="app">                   ← flex column
 *       <div data-main-frame>          ← header + hero, grouped
 *         <Header/>                     ← sticky top:0 (pins across the frame)
 *         <slot name="hero"/>           ← per-page hero (optional)
 *       </div>
 *       <div data-container-below>      ← the page content between hero & footer
 *         <slot/>                       ← default slot (the rest of the page)
 *       </div>
 *       <slot name="footer"><Footer/>   ← footer at the bottom (defaults to
 *                                          <Footer/>, overridable; hideFooter
 *                                          suppresses it)
 *     </div>
 *
 * Header is kept STICKY (not fixed) so it can live inside data-main-frame without
 * losing its pinning (a fixed element would re-anchor to a transformed wrapper).
 * data-container-below is flex-1 so it fills the viewport on short pages, keeping
 * the footer at the bottom.
 *
 * Slots: "hero" (per-page hero), "footer" (defaults to <Footer/>), default (rest).
 *
 * All other layouts should extend or use this as their base.
 * Ensures consistent structure and metadata across the entire site.
 */

import "../styles/global.css";
import HeadTags from "./HeadTags.astro";
import SEO from "./SEO.astro";
import Theme from "./Theme.astro";
import BodyTags from "./BodyTags.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import AskAi from "@/components/AskAi/AskAi";

export interface Props {
  /** Suppress the default site footer (e.g. when a page renders it itself,
   *  like the homepage curtain stack revealing the footer with an up-slide). */
  hideFooter?: boolean;
  [key: string]: any;  // Accept any props for SEO component
}

const { hideFooter = false, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {/* Theme setup (favicons, theme color) */}
    <Theme />
    
    {/* SEO meta tags */}
    <SEO title={seoProps.title} {...seoProps} />
    
    {/* Additional head tags (analytics scripts, etc.) */}
    <HeadTags />

    {/* Optional noindex for unpublished content */}
    {seoProps.noindex && <meta name="robots" content="noindex,nofollow" />}
  </head>

  <body class="antialiased">
    {/* Body-level scripts and elements */}
    <BodyTags />

    {/* App: flex column so the container-below flexes and the footer sits at the
        bottom even on short pages. */}
    <div id="app" class="min-h-screen flex flex-col">

      {/* Main frame — header + hero grouped. The header is STICKY (not fixed) so
          it pins across the frame while living inside this wrapper. */}
      <!-- <div class="main-frame relative flex flex-col" data-main-frame> -->
        <Header />
        <slot name="hero" />
      <!-- </div> -->

      {/* Container below — the page content between hero and footer. flex-1 so it
          fills the viewport on short pages (keeping the footer at the bottom). */}
      <div class="container-below flex-1 flex flex-col" data-container-below>
        <slot />

        {/* Ask-AI chat bar. Its trigger is position:fixed (floats over the
            viewport), so visibility is driven by observing #hero + <footer>: it
            only shows in the band between them, never over the hero or footer. */}
        <AskAi client:visible />
      </div>

      {/* Footer — sits at the bottom of the page below the container. Defaults to
          <Footer/> via slot fallback; hideFooter suppresses it (pages that render
          their own footer, e.g. the homepage curtain reveal). */}
      {!hideFooter && <slot name="footer"><Footer /></slot>}
    </div>
  </body>
</html>
