---
// src/layouts/FrontPageHero.astro
import { ctaData } from "@/content/siteData";
import ScrollIndicator from "@/components/ScrollIndicator.astro";
import Button from "@/components/Button/Button";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query } from "@/utils/query";

export interface Props {
  headline?: string;
  headlineLine2?: string;
  ctaText?: string;
  ctaLink?: string;
  statLabel?: string;
  statValue?: string;
  statDescription?: string;
  bodyText?: string;
  id?: string;
}

const {
  headline = "Built to",
  headlineLine2 = "grow your business.",
  ctaText = ctaData.text ?? "Start a project",
  ctaLink = ctaData.link ?? "/contact-us",
  statLabel = "EST. 2020",
  statValue = "Web design",
  statDescription = "Websites, AI products, and systems built for clarity and growth.",
  bodyText,
  id = "hero",
} = Astro.props;
---

<section
  id={id}
  class="relative w-full section-container min-h-screen flex flex-col hero-gap-py"
>

  <!-- Hero body — fills remaining space, stat pinned to bottom-right, headline top-left -->
  <div class="relative z-10 flex-1 flex flex-col justify-between w-full py-0 pb-12 lg:pb-16">

    <!-- Top row: headline left, (empty right) -->
    <div class="flex items-start justify-between gap-8 w-full">

      <!-- Left: headline + CTA -->
      <div class="max-w-3xl">
        <h1 class="text-[clamp(2.8rem,6.5vw,6rem)] font-light leading-[0.9] tracking-tight text-heading hero-gap-pb">
          {headline}<br />{headlineLine2}
        </h1>

        <Button variant="underline" href={ctaLink} className="mt-7" client:load>
          {ctaText}
        </Button>

        <ContentRenderer
          query={query("testimonials")
            .where((entry) => entry.data.featured === true)
            .limit(3)}
          variant="TestimonialCirclesVariant"
          className="mt-6"
          counterStart={10}
          counterEnd={100}
          counterDuration={1800}
          counterSuffix="+"
          counterLabel="Happy Clients"
        />
      </div>
    </div>

    <!-- Bottom row: scroll indicator centered, stat box pinned right -->
    <div class="flex items-end justify-between w-full">
      <!-- Left spacer (mirrors stat box width) -->
      <div class="hidden lg:block shrink-0 w-[340px]"></div>

      <!-- Scroll indicator centered -->
      <ScrollIndicator className="relative bottom-auto left-auto translate-x-0 static-in-row" />

      <!-- Right: stat box + body text -->
      <div class="hidden lg:flex flex-col items-start gap-4 shrink-0 w-[340px] text-left">
        <!-- Stat box -->
        <div class="bg-gradient border border-text/20 rounded-sm flex items-stretch overflow-hidden">
          <div class="flex flex-col items-center justify-center px-5 py-5 border-r border-text/20 min-w-[90px]">
            <!-- Globe icon -->
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-text">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
            </svg>
            <span class="text-[10px] text-text font-medium mt-2 tracking-widest">{statLabel}</span>
          </div>
          <div class="flex items-center justify-center px-6 py-5">
            <span class="text-[13px] font-semibold tracking-widest text-heading uppercase leading-snug max-w-[180px]">{statValue}</span>
          </div>
        </div>

        <!-- Body text -->
        {bodyText && (
          <p class="text-base text-text leading-relaxed">{bodyText}</p>
        )}
        {!bodyText && (
          <p class="text-lg text-text leading-relaxed">{statDescription}</p>
        )}
      </div>
    </div>
  </div>

  <slot />
</section>

<style>
  :root {
    --hero-gap: 1.5rem; /* 24px — matches py-6 / pb-6 */
  }
  @media (min-width: 1024px) {
    :root {
      --hero-gap: 2rem; /* 32px — matches lg:py-8 / lg:pb-8 */
    }
  }
  .hero-gap-py {
    padding-top: var(--hero-gap);
    padding-bottom: var(--hero-gap);
  }
  .hero-gap-pb {
    padding-bottom: var(--hero-gap);
  }
  /* Override ScrollIndicator's default absolute positioning when inline in the row */
  :global(.static-in-row) {
    position: static !important;
    transform: none !important;
    bottom: auto !important;
    left: auto !important;
  }
</style>
