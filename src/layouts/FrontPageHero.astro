---
// src/layouts/FrontPageHero.astro
import { ctaData } from "@/content/siteData";
import ScrollIndicator from "@/components/ScrollIndicator.astro";
import Button from "@/components/Button/Button";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByOrder } from "@/utils/query";

export interface Props {
  headline?: string;
  headlineLine2?: string;
  ctaText?: string;
  ctaLink?: string;
  statLabel?: string;
  statValue?: string;
  statDescription?: string;
  bodyText?: string;
  id?: string;
}

const {
  headline = "Built to",
  headlineLine2 = "grow your business.",
  ctaText = ctaData.text ?? "Start a project",
  ctaLink = ctaData.link ?? "/contact-us",
  statLabel = "EST. 2020",
  statValue = "Web design",
  statDescription = "Websites, AI products, and systems built for clarity and growth.",
  bodyText,
  id = "hero",
} = Astro.props;
---

<section
  id={id}
  class="relative w-full section-container min-h-[100svh] flex flex-col hero-gap-py"
>

  <!-- Hero body — headline pinned top, bottom row (buttons + arrow) pinned
       bottom via justify-between, on mobile and desktop alike. -->
  <div class="relative z-10 flex-1 flex flex-col justify-between w-full py-0 pb-12 lg:pb-16">

    <!-- Top row: headline left, (empty right) -->
    <div class="flex items-start justify-between gap-8 w-full">

      <!-- Left: headline (+ CTA on desktop) -->
      <div class="max-w-3xl md:pt-20 lg:pt-28">
        {/* Hero headline. heading-display sets the desktop clamp; on mobile we
            override to a smaller size so it doesn't dominate the viewport. */}
        <h1 class="heading-display text-[2.25rem]! sm:text-[2.75rem]! md:text-[clamp(2.8rem,6.5vw,6rem)]!">
          {headline}<br />{headlineLine2}
        </h1>

        {/* Mobile only: supporting text under the heading. On desktop this copy
            lives in the stat card (bottom-right) instead. */}
        <p class="support-text text-muted mt-5 max-w-[16rem] lg:hidden">
          {bodyText || statDescription}
        </p>

        {/* Mobile only: testimonial circles under the text. */}
        <ContentRenderer
          query={query("testimonials")
            .where((entry) => entry.data.featured === true)
            .limit(3)}
          variant="TestimonialCirclesVariant"
          className="mt-6 lg:hidden"
          counterStart={10}
          counterEnd={100}
          counterDuration={1800}
          counterSuffix="+"
          counterLabel="Happy Clients"
        />

        {/* CTAs — DESKTOP: under the headline (top-left). MOBILE: hidden here and
            shown in the bottom group instead. */}
        <div class="hidden lg:flex flex-wrap items-center gap-6 mt-8">
          <Button
            variant="primary"
            href={ctaLink}
            rightIcon="lu:arrow-up-right"
            className="rounded-xl px-6 py-3.5 eyebrow-text font-medium flex items-center gap-2 group shadow-md [&_svg]:transition-transform [&_svg]:duration-200 hover:[&_svg]:translate-x-[0.16rem] hover:[&_svg]:-translate-y-[0.16rem]"
            client:load
          >
            {ctaText}
          </Button>

          <Button
            variant="underline"
            href="/projects"
            className="!self-center"
            client:load
          >
            View Our Work
          </Button>
        </div>
      </div>
    </div>

    <!-- Bottom row — pinned to the bottom of the hero by the parent's
         justify-between. Mobile: CTA + circles group (left) above the scroll
         arrow; stats hidden. lg+: [circles] [scroll arrow centred] [stat box]. -->
    <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between w-full">
      {/* MOBILE-only group: CTAs + circles at the bottom-left (the desktop CTAs
          live up by the headline; the stats box is hidden on mobile and
          reappears in the About section). */}
      <div class="flex flex-col items-end gap-6 text-right lg:hidden">
        <div class="flex flex-wrap items-center justify-end gap-6">
          <Button
            variant="primary"
            href={ctaLink}
            rightIcon="lu:arrow-up-right"
            className="rounded-xl px-6 py-3.5 eyebrow-text font-medium flex items-center gap-2 group shadow-md [&_svg]:transition-transform [&_svg]:duration-200 hover:[&_svg]:translate-x-[0.16rem] hover:[&_svg]:-translate-y-[0.16rem]"
            client:load
          >
            {ctaText}
          </Button>
          <Button variant="underline" href="/projects" className="!self-center" client:load>
            View Our Work
          </Button>
        </div>
      </div>

      <!-- Desktop only: testimonial circles pinned bottom-left. -->
      <ContentRenderer
        query={query("testimonials")
          .where((entry) => entry.data.featured === true)
          .limit(3)}
        variant="TestimonialCirclesVariant"
        className="hidden lg:flex shrink-0 lg:w-[340px]"
        counterStart={10}
        counterEnd={100}
        counterDuration={1800}
        counterSuffix="+"
        counterLabel="Happy Clients"
      />

      <!-- Scroll indicator: centred in the row on desktop, below on mobile -->
      <ScrollIndicator href="#solutions-stacked-deck-section" className="order-last lg:order-none self-center lg:self-auto relative bottom-auto left-auto translate-x-0 static-in-row" />

      <!-- Stat box + body text — DESKTOP bottom-right only. Hidden on mobile
           (the same stats reappear in the About section). -->
      <ContentRenderer
        query={query("stats").orderBy(sortByOrder())}
        variant="HeroStatsVariant"
        description={bodyText || statDescription}
        showHeadingSection={false}
        className="hidden lg:flex shrink-0 lg:w-[380px]"
      />
    </div>
  </div>

  <slot />
</section>

<style>
  :root {
    --hero-gap: 1.5rem; /* 24px — matches py-6 / pb-6 */
  }
  @media (min-width: 1024px) {
    :root {
      --hero-gap: 2rem; /* 32px — matches lg:py-8 / lg:pb-8 */
    }
  }
  .hero-gap-py {
    padding-top: var(--hero-gap);
    padding-bottom: var(--hero-gap);
  }
  /* Override ScrollIndicator's default absolute positioning when inline in the row */
  :global(.static-in-row) {
    position: static !important;
    transform: none !important;
    bottom: auto !important;
    left: auto !important;
  }
</style>
