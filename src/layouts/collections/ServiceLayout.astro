---
// src/layouts/collections/ServiceLayout.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import SecondaryHero from "@/layouts/SecondaryHero.astro";
import SolutionsHero from "@/layouts/SolutionsHero.astro";
import AboutSection from "@/components/AboutSection/AboutSection.astro";
import Icon from "@/components/Icon";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import Marquee from "@/components/Marquee.astro";
import PortfolioSectionVertical from "@/components/Portfolio/PortfolioSectionVertical.astro";
import { children } from "@/utils/query/snippets";
import { humanizeSlug } from "@/utils/string";
import type { CollectionLayoutProps } from "./types";

const { entry, seoProps = {} } = Astro.props as CollectionLayoutProps;
const data = entry?.data || {};

const includes: { title: string; body: string }[] = data.includes ?? [];
const steps:    { title: string; body: string }[] = data.steps    ?? [];

// Breadcrumb/eyebrow: the page title, falling back to the humanized slug.
const eyebrow = data.title ?? humanizeSlug(entry?.id ?? "");

// Big hero heading: the `heading` field (string or {before,text,after}),
// falling back to the title so existing pages without a heading still work.
const headingText =
  typeof data.heading === "string"
    ? data.heading
    : data.heading
      ? [data.heading.before, data.heading.text, data.heading.after]
          .filter(Boolean)
          .join(" ")
      : data.title;

// Capabilities that belong to this entry (only solution pages have these —
// capability pages resolve to an empty set, so the section won't render there).
const isSolution = entry?.collection === "solutions";
const showHomepageAbout = isSolution && entry?.id === "websites";
// The vertical filmstrip portfolio only shows on the Websites solution page.
const showPortfolioFilmstrip = isSolution && entry?.id === "websites";

const aboutEyebrow = data.aboutEyebrow ?? "About";
const aboutStatement =
  data.aboutStatement ??
  "We build websites that turn your online presence into a clear, fast, and trustworthy part of the business.";
const aboutLeftText =
  data.aboutLeftText ??
  "We design for longevity, clarity first, and a site structure that supports real growth.";
const aboutRightText =
  data.aboutRightText ??
  "Our mission is to make your website feel sharp, easy to manage, and effective at bringing in the right work.";
const aboutCtaText = data.aboutCtaText ?? "Explore Our Story";
const aboutCtaLink = data.aboutCtaLink ?? "/about-us";
const aboutStickyHeight = data.aboutStickyHeight ?? "220svh";
const aboutShowStats = data.aboutShowStats ?? true;
---

<BaseLayout {...seoProps}>
  <main class="flex-1 bg-bg">

    <!-- ── Hero: eyebrow = title (slug fallback), h1 = heading.
         Solutions use the dedicated SolutionsHero; everything else (capabilities)
         keeps the SecondaryHero. ── -->
    {isSolution ? (
      <SolutionsHero
        eyebrow={eyebrow}
        title={headingText}
        description={data.description}
      />
    ) : (
      <SecondaryHero
        eyebrow={eyebrow}
        title={headingText}
        description={data.description}
      />
    )}

    {showHomepageAbout && (
      <>
        <AboutSection
          eyebrow={aboutEyebrow}
          statement={aboutStatement}
          leftText={aboutLeftText}
          rightText={aboutRightText}
          ctaText={aboutCtaText}
          ctaLink={aboutCtaLink}
          stickyHeight={aboutStickyHeight}
          showStats={aboutShowStats}
        />

        <div class="sl-marquee-fullbleed">
          <Marquee />
        </div>
      </>
    )}

    <!-- ══════════════════════════════════════════
         MIDDLE CONTENT
    ══════════════════════════════════════════ -->
    <div class:list={["page-container", "sl-page", showHomepageAbout && "sl-page--websites"]}>

      <!-- 1. TAGLINE / ABOUT FALLBACK ───────────────────── -->
      {!showHomepageAbout && data.tagline && (
        <section class="sl-tagline-section" aria-label="Service tagline">
          {data.icon && (
            <div class="sl-tagline-icon" aria-hidden="true">
              <Icon icon={data.icon} size="xl" className="text-heading/20" />
            </div>
          )}
          <h2 class="sl-tagline">{data.tagline}</h2>
        </section>
      )}

      <!-- 2. WHAT'S INCLUDED ───────────────────── -->
      {!showHomepageAbout && includes.length > 0 && (
        <section class="sl-section" aria-labelledby="sl-includes-heading">
          <p class="sl-label" id="sl-includes-heading" aria-label="What is included">
            What's Included
          </p>
          <ul class="sl-includes-grid" role="list">
            {includes.map((item, i) => (
              <li class="sl-include-card reveal-item" style={`--rv-delay:${i * 0.07}s`}>
                <span class="sl-include-num" aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class="sl-include-title">{item.title}</h3>
                <p class="sl-include-body">{item.body}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- 2b. PORTFOLIO FILMSTRIP (Websites page only) — full-bleed, pins and
           peels off the top on scroll, revealing the process section below. ── -->
      {showPortfolioFilmstrip && (
        <div class="sl-filmstrip-fullbleed">
          <PortfolioSectionVertical ctaLink="/projects" placeholderMedia={true}>
            <ContentRenderer
              slot="under-text"
              query={children("capabilities", entry.id)}
              variant="CapabilitiesListVariant"
            />
          </PortfolioSectionVertical>
        </div>
      )}

      <!-- 3. PROCESS — animated "Our Process" renderer ── -->
      {steps.length > 0 && (
        <ContentRenderer
          variant="ProcessVariant"
          items={steps}
          eyebrow="Our Process"
          title="How we work"
          description="A repeatable method applied across every engagement."
        />
      )}

    </div>
  </main>
</BaseLayout>

<!---------------------------------------------------------------------------->
<style>

  .sl-page {
    padding-block: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .sl-page--websites {
    gap: clamp(2rem, 4vw, 3rem);
  }

  /* Full-bleed escape: break the marquee out of the centered page-container
     so it spans the full viewport width, like the homepage marquee. */
  .sl-marquee-fullbleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
  }

  /* Full-bleed escape for the pinned vertical filmstrip so it spans the full
     viewport width and pins/peels cleanly outside the centered page flow. The
     parent flex `gap` would otherwise add space around the pinned frame, so we
     cancel it with negative margins matching .sl-page's gap. */
  .sl-filmstrip-fullbleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-block: calc(-1 * clamp(3rem, 6vw, 5rem));
  }

  /* ── 1. TAGLINE ── */
  .sl-tagline-section {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .sl-tagline-icon {
    line-height: 1;
  }

  .sl-tagline {
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 20ch;
    text-wrap: balance;
  }

  /* ── SECTION WRAPPER ── */
  .sl-section {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2rem);
  }

  .sl-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 45%, transparent);
  }

  /* ── 2. INCLUDES GRID ── */
  .sl-includes-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: color-mix(in srgb, var(--color-heading) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-heading) 8%, transparent);
    border-radius: 0.875rem;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .sl-includes-grid { grid-template-columns: 1fr; }
  }

  .sl-include-card {
    background: var(--color-bg);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: background 0.2s ease;
  }
  .sl-include-card:hover {
    background: color-mix(in srgb, var(--color-heading) 3%, var(--color-bg));
  }

  .sl-include-num {
    font-size: 0.65rem;
    font-family: monospace;
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--color-text) 30%, transparent);
  }

  .sl-include-title {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    font-weight: 600;
    color: var(--color-heading);
    letter-spacing: -0.01em;
  }

  .sl-include-body {
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    color: color-mix(in srgb, var(--color-text) 65%, transparent);
    line-height: 1.7;
    font-weight: 300;
  }

  /* ── 3. PROCESS STEPS ── */
  .sl-process-section {
    border-top: 1px solid color-mix(in srgb, var(--color-heading) 8%, transparent);
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .sl-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
    counter-reset: steps;
  }

  @media (max-width: 700px) {
    .sl-steps { grid-template-columns: 1fr; }
  }

  .sl-step {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 2px solid color-mix(in srgb, var(--color-heading) 12%, transparent);
    position: relative;
    transition: border-color 0.3s ease;
  }
  .sl-step:hover {
    border-top-color: color-mix(in srgb, var(--color-heading) 45%, transparent);
  }

  .sl-step-num {
    font-size: 0.65rem;
    font-family: monospace;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--color-text) 30%, transparent);
  }

  .sl-step-title {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    font-weight: 600;
    color: var(--color-heading);
    letter-spacing: -0.01em;
  }

  .sl-step-body {
    font-size: clamp(0.8rem, 1.2vw, 0.875rem);
    color: color-mix(in srgb, var(--color-text) 65%, transparent);
    line-height: 1.75;
    font-weight: 300;
  }

  /* ── REVEAL ANIMATIONS ── */
  .reveal-item {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity   0.65s cubic-bezier(0.16, 1, 0.3, 1) var(--rv-delay, 0s),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1) var(--rv-delay, 0s);
  }
  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item { opacity: 1; transform: none; transition: none; }
  }
  :global([data-a11y-motion="reduced"]) .reveal-item {
    opacity: 1; transform: none; transition: none;
  }

</style>

<script>
  function initServicePage(): void {
    const els = document.querySelectorAll<HTMLElement>(".reveal-item");
    if (!els.length) return;
    const obs = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add("is-visible");
          obs.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    els.forEach((el) => obs.observe(el));
  }
  initServicePage();
  document.addEventListener("astro:page-load", initServicePage);
</script>
