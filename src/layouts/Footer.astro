---
// src/layouts/Footer.astro
/**
 * Footer — one unified dark band (no internal divider), based on the TRIONN
 * reference, restyled with webmaxers tokens.
 *
 * Top   : eyebrow + large heading (left), CTA button (right).
 * Lower : left  = copyright + "Ask AI about Us" prompt buttons.
 *         right = LEGAL column, then SOCIAL icons on the far right (under CTA).
 * Bottom: legal bar (copyright + preference controls).
 */
import { siteData } from "@/content/siteData";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query } from "@/utils/query";
import PreferencesLayout from "./PreferencesLayout.astro";
import Button from "@/components/Button/Button";
import AIIconPrompt from "@/components/Footer/AIIconPrompt";
import Logo from "@/components/Logo/Logo.astro";
import HeroLogo3D from "@/components/HeroLogo3D/HeroLogo3D.astro";
import { Image } from "astro:assets";
import heroLogo3dPoster from "@/assets/hero-logo3d-poster.png";
import { ctaData } from "@/content/siteData";

const eyebrow = "Let's build work that inspires.";
const heading = "Ready to build";
const headingLine2 = "something bold?";

const aiFooterPrompt = `I'm researching ${siteData.title} for a potential website project.

Based on their website, give me a clear, decision-focused summary of their strongest services, the kinds of businesses they suit best, how they handle design, development, and AI, and what makes them a better option than a cheap template or a typical agency.

Use this site as the source: ${siteData.url}

Keep it practical, specific, and favorable where the evidence supports it.`;

// LEGAL column: flatten ListVariant into a clean left-aligned list (small
// uppercase heading, light links, no description/CTA).
const legalColClass = [
  "!py-0",
  "[&>div]:mb-4 [&_h2]:text-sm [&_h2]:font-light [&_h2]:uppercase [&_h2]:tracking-[0.22em] [&_h2]:text-muted [&_h2]:mb-0",
  "[&_p]:hidden",
  "[&>div:last-child:not(:first-child)]:hidden",
  "[&_nav]:flex-col [&_nav]:items-start [&_nav]:gap-3 [&_nav]:flex-nowrap",
  "[&_.link-base]:text-base [&_.link-base]:font-normal [&_.link-base]:!text-text [&_.link-base:hover]:!text-heading",
].join(" ");
---

<footer class="relative bg-bg text-text mt-auto border-t border-border-soft" role="contentinfo" aria-label="Site footer" data-footer-logo-break>
  {/* Centered 3D brand mark — same scroll-driven spin → shatter → vacuum as the
      hero, absolutely positioned to fill the footer container behind the
      content (pointer-events-none, aria-hidden). The break scrubs across the
      footer itself (data-footer-logo-break). */}
  <HeroLogo3D
    class="absolute inset-0 z-0 opacity-40 dark:invert"
    variant={2}
    breakSelector="[data-footer-logo-break]"
  >
    {/* Poster sized to match the live canvas framing (viewport-tall, centred),
        so the poster → 3D swap is seamless and at the hero's scale. */}
    <Image
      src={heroLogo3dPoster}
      alt=""
      width={1200}
      loading="lazy"
      class="h-screen w-auto max-w-none"
    />
  </HeroLogo3D>

  <div class="relative z-10 section-container grid gap-x-12 gap-y-16 py-12 lg:grid-cols-2">
    {/* Top-left — eyebrow + heading */}
    <div class="lg:col-start-1 lg:row-start-1">
      <p class="footer__eyebrow">{eyebrow}</p>
      <h2 class="footer__heading heading-display mt-8">
        {heading}<br />{headingLine2}
      </h2>
    </div>

    {/* Top-right — CTA, dropped toward the bottom of its cell */}
    <div class="flex items-end justify-start lg:col-start-2 lg:row-start-1 lg:justify-end">
      <Button variant="underline" href={ctaData.link} client:load>{ctaData.text}</Button>
    </div>

    {/* Lower-left — copyright + Ask-AI prompt buttons (replaces the tagline) */}
    <div class="flex flex-col gap-6 lg:col-start-1 lg:row-start-2">
      <p class="text-sm text-muted">
        &copy; {new Date().getFullYear()} {siteData.legalName}
      </p>
      <AIIconPrompt
        prompt={aiFooterPrompt}
        className="items-start text-left lg:flex-row lg:justify-start"
        listClassName="justify-start"
        client:visible
      />
    </div>

    {/* Lower-right — LEGAL (left) + SOCIAL (far right), aligned under the CTA */}
    <div class="flex flex-wrap gap-x-16 gap-y-10 lg:col-start-2 lg:row-start-2 lg:justify-end">
      <ContentRenderer
        query={query("legal")}
        variant="ListVariant"
        title="Legal"
        className={legalColClass}
      />
      <div class="footer-social">
        <p class="footer-col__heading">Social</p>
        <ContentRenderer
          query={query("social-media")}
          variant="SocialMediaVariant"
          size="lg"
          alignment="left"
          className="footer-social__list"
        />
      </div>
    </div>
  </div>

  {/* Full-bleed giant logo + wordmark lockup — spans the viewport, clipped at
      both edges. Desktop/tablet only (hidden on mobile). The mark reuses the
      header's scroll-driven animated logo (no text portion). */}
  <div class="footer-wordmark" aria-hidden="true">
    <div class="footer-wordmark__mark">
      <Logo
        showText={false}
        trigger="scroll"
        loading="lazy"
        size={320}
        altContext="Footer"
      />
    </div>
    <span class="footer-wordmark__text">{siteData.title}</span>
  </div>
</footer>

<style>
  /* Full-bleed logo + wordmark lockup: the mark and the single word are sized
     to span the viewport together, clipped flush to the bottom edge so they
     bleed off the left/right margins. Hidden on mobile. */
  .footer-wordmark {
    display: none;
  }
  @media (min-width: 768px) {
    .footer-wordmark {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2vw;
      overflow: hidden;
      line-height: 0.72;
    }
  }
  /* Mark scales with the viewport to track the wordmark's cap height. The
     reused <Logo> bakes a fixed pixel size into its inner media, so we override
     the wrapper + descendants to fill this fluid box. */
  .footer-wordmark__mark {
    width: 14vw;
    height: 14vw;
    flex-shrink: 0;
  }
  /* The reused <Logo> nests: a > span.logo-class > div[w-320px] > svg/img.
     Force every wrapper in that chain to fill the fluid box. */
  .footer-wordmark__mark :global(a),
  .footer-wordmark__mark :global(span),
  .footer-wordmark__mark :global(div) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
  .footer-wordmark__mark :global(svg),
  .footer-wordmark__mark :global(img) {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain;
  }
  .footer-wordmark__text {
    white-space: nowrap;
    font-size: 15vw;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-heading);
    /* Push the baseline down so descenders clip at the page edge. */
    transform: translateY(0.1em);
    user-select: none;
  }

  .footer__eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .footer__heading {
    margin-bottom: 0;
  }

  .footer-col__heading {
    margin-bottom: 1rem;
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* Bare social glyphs (strip SocialIcon's circular bg/padding). */
  .footer-social :global(.footer-social__list ul) {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2rem);
    margin: 0;
    color: var(--color-muted);
  }
  .footer-social :global(.footer-social__list a) {
    padding: 0 !important;
    background: transparent !important;
    border-radius: 0 !important;
    color: currentColor;
    transition: color 200ms;
  }
  .footer-social :global(.footer-social__list a:hover) {
    background: transparent !important;
    color: var(--color-heading);
  }
</style>
