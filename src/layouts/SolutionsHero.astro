---
// src/layouts/SolutionsHero.astro
/**
 * Solutions Hero Layout
 *
 * Duplicate of SecondaryHero, dedicated to solution pages so it can be
 * specialized independently. Full-height hero: eyebrow + heading centred,
 * description pinned to the bottom, scroll arrow on the right.
 */

import { getAuthorName } from "@/layouts/collections/helpers/layoutHelpers";
import LogoMark from "@/components/Logo/LogoMark.astro";
import ScrollIndicator from "@/components/ScrollIndicator.astro";

export interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  image?: any; // Astro image asset or public path
  publishDate?: Date | string;
  author?: string | { collection: string; id: string };
  readingTime?: number;
  className?: string;
  minHeight?: string;
  imageClass?: string;
  overlayClass?: string;
  textColorClass?: string;
  hideText?: boolean;
}

const {
  title,
  eyebrow,
  description,
  image,
  publishDate,
  author,
  readingTime,
  className = "",
  minHeight = "100vh",
  textColorClass = "text-heading",
  hideText = false,
} = Astro.props;
---

<section class={`relative bg-bg ${className}`}>
  <div
    class="relative flex flex-col overflow-hidden"
    style={`min-height: ${minHeight}`}
  >
    {/* Hero content — eyebrow + title centred in the available space */}
    {!hideText && (
      <div class="relative z-10 flex flex-1 items-center justify-center container mx-auto px-4 py-24">
        <div class={`max-w-4xl mx-auto text-center ${textColorClass}`}>
          {
            eyebrow && (
              <p class="inline-flex items-center justify-center gap-2.5 mb-6 text-sm md:text-base font-semibold tracking-[0.28em] uppercase text-current/90">
                <LogoMark size={20} imgClass="block w-4 h-4 md:w-5 md:h-5" />
                {eyebrow}
              </p>
            )
          }

          <h1 class="heading-display">
            {title}
          </h1>

          {/* Metadata row with icons */}
          {
            (publishDate || author || readingTime) && (
              <div class="mt-8 flex flex-wrap justify-center gap-4 md:gap-6 text-sm md:text-base opacity-90">
                {publishDate && (
                  <time
                    datetime={new Date(publishDate).toISOString()}
                    class="flex items-center gap-2"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    {new Date(publishDate).toLocaleDateString()}
                  </time>
                )}

                {author && (
                  <span class="flex items-center gap-2">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                      />
                    </svg>
                    By {getAuthorName(author)}
                  </span>
                )}

                {readingTime && (
                  <span class="flex items-center gap-2">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    {readingTime} min read
                  </span>
                )}
              </div>
            )
          }
        </div>
      </div>
    )}

    {/* Bottom row: description (pinned to the bottom) + scroll arrow on the right */}
    {!hideText && (
      <div class="relative z-10 container mx-auto px-4 pb-12 md:pb-16">
        <div class="flex items-end justify-between gap-6">
          <div class={`max-w-3xl ${textColorClass}`}>
            {description && (
              <p class="text-base md:text-lg lg:text-xl opacity-80 leading-relaxed">
                {description}
              </p>
            )}
          </div>

          <ScrollIndicator className="solh-scroll-arrow static bottom-auto left-auto shrink-0" />
        </div>
      </div>
    )}
  </div>

  {/* Optional slot for additional content below hero */}
  <slot />
</section>

<style>
  /* The shared ScrollIndicator bounces with translateX(-50%) for its default
     centred placement. Here it sits inline on the right, so re-key the bounce
     to move vertically only (no horizontal offset). */
  :global(.solh-scroll-arrow.scroll-indicator) {
    animation-name: solh-arrow-bounce;
  }

  @keyframes solh-arrow-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.solh-scroll-arrow.scroll-indicator) {
      animation: none;
    }
  }
</style>
