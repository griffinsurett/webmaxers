---
// src/layouts/HeroStatBlock.astro
// The hero's stats (EST., experience, and revenue metrics) plus description line.
// Upgraded to a clean, frameless horizontal-row layout with vertical divider lines.

import Counter from "@/components/Counter.astro";

interface Props {
  statLabel: string;
  statValue: string;
  statDescription: string;
  bodyText?: string;
  class?: string;
}

const {
  statLabel,
  statValue,
  statDescription,
  bodyText,
  class: className = "",
} = Astro.props;

// Split statLabel (e.g. "EST. 2019") into label ("EST.") and year ("2019")
const labelMatch = statLabel.match(/^(EST\.)\s*(.*)$/i);
const estLabel = labelMatch ? labelMatch[1] : "EST.";
const estYear = labelMatch ? labelMatch[2] : "2019";

// Split statValue into experience and revenue parts
const parts = statValue.split(/\.\s*/).filter(Boolean);

const metric1 = parts[0] || "7+ years";
const metric2 = parts[1] || "$1M+ clients";

const parseMetric = (text: string, defaultLabel: string) => {
  const match = text.match(/^(\$?\d+[a-zA-Z\+]*)(.*)$/);
  if (match) {
    return {
      value: match[1].trim(),
      label: defaultLabel
    };
  }
  return {
    value: text,
    label: defaultLabel
  };
};

const expMetric = parseMetric(metric1, "Years of Experience");
const revMetric = parseMetric(metric2, "Revenue Generated");

// Check if experience is numeric for counter animation
const expNumMatch = expMetric.value.match(/^(\d+)(\+?)$/);
const isExpNumeric = !!expNumMatch;
const expNumber = expNumMatch ? parseInt(expNumMatch[1], 10) : 7;
const expSuffix = expNumMatch ? expNumMatch[2] : "+";
---

<div class:list={["flex flex-col items-center lg:items-start gap-6 w-full group/widget", className]}>
  <!-- Horizontal Row Layout with Vertical Dividers -->
  <div class="w-full grid grid-cols-3 divide-x divide-text/15 py-2">
    
    <!-- Section 1: Establishment -->
    <div class="flex flex-col items-center text-center px-1.5 group/sec1">
      <div class="h-8 flex items-center justify-center text-text/60 group-hover/sec1:text-primary group-hover/sec1:scale-110 transition-all duration-300">
        <!-- Calendar Icon -->
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      </div>
      <span class="text-[10px] text-text/45 uppercase tracking-widest font-semibold mt-2.5 leading-none">
        {estLabel}
      </span>
      <span class="text-[13px] font-bold text-heading mt-1 leading-none tracking-wider">
        {estYear}
      </span>
    </div>

    <!-- Section 2: Experience -->
    <div class="flex flex-col items-center text-center px-1.5 group/sec2">
      <div class="h-8 flex items-center justify-center gap-1.5 text-text/80 group-hover/sec2:text-primary transition-colors duration-300">
        <!-- Users/People Icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/sec2:scale-110 transition-transform duration-300">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 00-3-3.87" />
          <path d="M16 3.13a4 4 0 010 7.75" />
        </svg>
        <span class="text-[15px] lg:text-[16px] font-bold text-heading tracking-tight leading-none">
          {isExpNumeric ? (
            <Counter 
              start={1} 
              end={expNumber} 
              suffix={expSuffix} 
              duration={1200}
              class="font-bold text-heading tracking-tight group-hover/sec2:text-primary transition-colors duration-300"
            />
          ) : (
            expMetric.value
          )}
        </span>
      </div>
      <span class="text-[10px] text-text/50 font-medium mt-2.5 leading-tight tracking-wide">
        {expMetric.label}
      </span>
    </div>

    <!-- Section 3: Revenue -->
    <div class="flex flex-col items-center text-center px-1.5 group/sec3">
      <div class="h-8 flex items-center justify-center gap-1.5 text-text/80 group-hover/sec3:text-primary transition-colors duration-300">
        <!-- Trend Up Icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover/sec3:scale-110 transition-transform duration-300">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
          <polyline points="16 7 22 7 22 13" />
        </svg>
        <span class="text-[15px] lg:text-[16px] font-bold text-heading tracking-tight leading-none">
          {revMetric.value}
        </span>
      </div>
      <span class="text-[10px] text-text/50 font-medium mt-2.5 leading-tight tracking-wide">
        {revMetric.label}
      </span>
    </div>

  </div>

  <!-- Description / Body text -->
  {(bodyText || statDescription) && (
    <p class="text-sm lg:text-base text-text/70 leading-relaxed text-center lg:text-left w-full mt-1 group-hover/widget:text-text/90 transition-colors duration-500">
      {bodyText || statDescription}
    </p>
  )}
</div>
