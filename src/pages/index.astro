---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteData } from "@/content/siteData";
import FrontPageHero from "@/layouts/FrontPageHero.astro";
import AboutSection from "@/components/AboutSection/AboutSection.astro";
import TestimonialCarousel from "@/components/TestimonialCarousel/TestimonialCarousel.astro";
import Marquee from "@/components/Marquee.astro";
import PortfolioSection from "@/components/Portfolio/PortfolioSection.astro";
import CurtainStack from "@/components/CurtainStack/CurtainStack.astro";
import HeroLogo3D from "@/components/HeroLogo3D/HeroLogo3D.astro";
import SolutionsScroll from "@/components/SolutionsScroll/SolutionsScroll.astro";
import Footer from "@/layouts/Footer.astro";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import { query, sortByDate } from "@/utils/query";
import { Image } from "astro:assets";
import heroLogo3dPoster from "@/assets/hero-logo3d-poster.png";
import Starfield from "@/components/Starfield/Starfield.astro";

// Latest 3 blog posts for the homepage preview curtain layer.
const latestPosts = query("blog")
  .where((e) => !e.data.draft)
  .orderBy(sortByDate("publishDate", "desc"))
  .limit(3);
---

<BaseLayout title="Home" description={siteData.description} hideFooter>
  {
    /* data-logo-break spans the WHOLE page (main + footer) so the 3D logo's
       break scrubs across the entire scroll: it shatters near the top, drifts as
       rubble behind the lower sections, then REASSEMBLES as you reach the footer.
       The logo canvas is fixed full-viewport and never hides (hideOnLeave=false). */
  }
  <div data-logo-break>
  <main class="flex-1 relative z-10">
    <div class="relative">
      {
        /* Dark-mode starfield: the backmost fixed layer, behind the 3D logo.
           It's the dark-mode background from the top of the page down to the
           CurtainStack — whose opaque card layers cover it once you scroll in.
           Hidden in light mode (the canvas CSS handles that). */
      }
      <!-- <Starfield class="-z-20" /> -->

      <HeroLogo3D class="fixed inset-0 -z-10 opacity-40 dark:invert" hideOnLeave={false}>
        {
          /* Poster: a render of the 3D logo at progress 0, captured on a SQUARE
            canvas with the same perspective camera. The live canvas frames the
            logo by VERTICAL fov (its on-screen height is a fixed fraction of the
            viewport height at any width), so we size the poster by height and
            centre it — matching the live logo's size exactly, seamless swap. */
        }
        <Image
          src={heroLogo3dPoster}
          alt=""
          width={1200}
          loading="eager"
          class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-1/2 md:h-full w-auto"
        />
      </HeroLogo3D>

      <!-- <div class="px-6 md:px-[80px]"> -->
      <FrontPageHero
        headline="Designed to"
        headlineLine2="grow your business."
        ctaText="Start a project"
        ctaLink="/contact-us"
        statLabel={`EST. 2019`}
        statValue="7+ years. $1M+ clients. Dominant results."
        statDescription="Websites, AI products, and systems built for clarity, scale, and growth."
      />

      <!-- Solutions: pinned stacking-card deck (cards fold up on scroll). -->
      <SolutionsScroll />

      <!-- About Section (includes both top reveal and bottom content) -->
      <AboutSection
        statement={`${siteData.title} is an independent digital studio crafting meaningful brand experiences through strategy, design, and technology.`}
        leftText="We design for longevity, clarity first, craft always, built to scale."
        rightText="Our mission is to make technology feel human by designing digital products that are intuitive, purposeful, and meaningful to people."
        ctaText="Explore Our Story"
        ctaLink="/about-us"
        showStats
      />
      <!-- </div> -->

      <!-- Marquee: full-bleed, manages its own horizontal escape -->
      <Marquee />
    </div>

    {
      /*
      Curtain reveal chain — full-bleed layers stacked on one pinned timeline
      (top → bottom):
        1. filmstrip    panels glide left, then the whole layer peels off-LEFT
        2. testimonials revealed in place on the fire bg, then slides UP away
        3. footer       revealed beneath as the final resting layer
      Each layer covers the next and moves off to uncover it; nothing scrolls
      up into view. Edit/reorder layers here — CurtainStack sequences them.
    */
    }
    <CurtainStack flattenMobile>
      <div data-curtain-layer data-move="left">
        <PortfolioSection ctaLink="/projects" />
      </div>
      {/* Blog preview — the curtain's resting layer (revealed when the portfolio
          peels off left). Transparent, so the fixed 3D logo shows through. */}
      <div data-curtain-layer data-move="none" class="curtain-blog-layer">
        <ContentRenderer
          query={latestPosts}
          variant="BlogVariant"
          appearance="dark"
          eyebrow="From the journal"
          title="Latest writing"
          columns={3}
          collectionUrl="/blog"
        />
      </div>
    </CurtainStack>

    {/* Testimonials — now a normal 2D section (no own background), scrolling in
        flow over the persistent 3D-logo bg after the pinned curtain releases. */}
    <section id="logo-scene">
      <TestimonialCarousel />
    </section>
  </main>

  {/* Footer — plain 2D, scrolls normally after the curtain releases. */}
  <Footer />
  </div>
</BaseLayout>

<style>
  /* Blog layer = the curtain's resting layer (revealed when the portfolio peels
     off left). Centred in the pinned frame on desktop (it fits in one viewport).
     Transparent so the fixed 3D logo / page bg shows through behind it. */
  :global(.curtain-blog-layer) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: transparent;
  }

  /* Mobile: the stacked blog grid is TALLER than the 100vh curtain frame, so
     centring it pushes the top out of view. Top-align it (and let it scroll
     within the frame) so it's revealed from its highest point as the portfolio
     peels off. */
  @media (max-width: 767px) {
    :global(.curtain-blog-layer) {
      justify-content: flex-start;
      overflow-y: auto;
    }
  }

  /* Reduced motion: the stack flattens to normal flow — the blog layer returns
     to a normal block (no forced height / centring). */
  @media (prefers-reduced-motion: reduce) {
    :global(.curtain-blog-layer) {
      display: block;
      overflow: visible;
    }
  }
</style>