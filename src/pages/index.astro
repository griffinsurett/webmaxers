---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteData } from "@/content/siteData";
import FrontPageHero from "@/layouts/FrontPageHero.astro";
import AboutSection from "@/components/AboutSection/AboutSection.astro";
import TestimonialCarousel from "@/components/TestimonialCarousel/TestimonialCarousel.astro";
import Marquee from "@/components/Marquee.astro";
import PortfolioSection from "@/components/Portfolio/PortfolioSection.astro";
import ServicesScene from "@/components/ServicesScene/ServicesScene.astro";
import LogoScene from "@/components/LogoScene/LogoScene.astro";
import CurtainStack from "@/components/CurtainStack/CurtainStack.astro";
---

<BaseLayout title="Home" description={siteData.description}>
  <main class="flex-1">
    <!-- <div class="px-6 md:px-[80px]"> -->
      <FrontPageHero
        headline="Designed to"
        headlineLine2="grow your business."
        ctaText="Start a project"
        ctaLink="/contact-us"
        statLabel={`EST. 2019`}
        statValue="7+ years. $1M+ clients. Dominant results."
        statDescription="Websites, AI products, and systems built for clarity, scale, and growth."
      />

      <!-- About Section (includes both top reveal and bottom content) -->
      <AboutSection
        statement="Webmaxers is an independent digital studio crafting meaningful brand experiences through strategy, design, and technology."
        leftText="We design for longevity, clarity first, craft always, built to scale."
        rightText="Our mission is to make technology feel human by designing digital products that are intuitive, purposeful, and meaningful to people."
        ctaText="Explore Our Story"
        ctaLink="/about-us"
      />
    <!-- </div> -->

    <!-- Marquee: full-bleed, manages its own horizontal escape -->
    <Marquee />

    {/*
      Curtain reveal chain — four full-bleed layers stacked on one pinned
      timeline (top → bottom):
        1. filmstrip   panels glide left, then the whole layer peels off-LEFT
        2. services    revealed in place; runs its phases, then slides UP away
        3. logo        scroll-scrubbed brand logo; revealed in place, then UP away
        4. testimonials revealed in place underneath — the final resting layer
      Each layer covers the next and moves off to uncover it; nothing scrolls
      up into view. Edit/reorder layers here — CurtainStack sequences them.
    */}
    <CurtainStack>
      <div data-curtain-layer data-move="left">
        <PortfolioSection ctaLink="/projects" />
      </div>
      <div data-curtain-layer data-move="up">
        <ServicesScene />
      </div>
      <div data-curtain-layer data-move="up">
        <LogoScene />
      </div>
    </CurtainStack>
            <TestimonialCarousel />

  </main>
</BaseLayout>

<style>
  /* The testimonials layer is a padded block, not full-bleed — centre it in the
     pinned viewport so it reads well while it's the revealed bottom layer. The
     component carries its own solid background. On mobile / reduced motion the
     stack flattens and the centring is a no-op. */
  .curtain-layer--testimonials {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--color-bg);
  }
</style>
